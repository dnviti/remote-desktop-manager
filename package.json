{
  "name": "arsenale",
  "version": "1.7.1",
  "description": "Web-based remote desktop manager for SSH and RDP connections with encrypted vault, team sharing, and multi-tenant support",
  "author": "Daniele Viti <daniele@dnviti.dev>",
  "license": "BUSL-1.1",
  "homepage": "https://github.com/dnviti/arsenale",
  "repository": {
    "type": "git",
    "url": "https://github.com/dnviti/arsenale.git"
  },
  "bugs": {
    "url": "https://github.com/dnviti/arsenale/issues"
  },
  "keywords": [
    "remote-desktop",
    "ssh",
    "rdp",
    "guacamole",
    "web-terminal",
    "sftp",
    "xterm",
    "vault",
    "multi-tenant"
  ],
  "private": true,
  "workspaces": [
    "client",
    "extra-clients/browser-extensions"
  ],
  "scripts": {
    "predev": "make dev",
    "backend:build": "./scripts/run-go.sh build ./...",
    "backend:generate": "./scripts/run-go.sh run github.com/sqlc-dev/sqlc/cmd/sqlc@v1.30.0 generate -f sqlc.yaml",
    "backend:test": "./scripts/run-go.sh test ./...",
    "go:build": "./scripts/go-build-all.sh",
    "go:test": "./scripts/go-test-all.sh",
    "db:bootstrap": "./scripts/db-migrate.sh up",
    "db:push": "npm run db:migrate",
    "db:status": "./scripts/db-migrate.sh status",
    "dev": "npm run dev:client:wait",
    "dev:client": "npm run dev -w client",
    "dev:client:wait": "wait-on -t 120000 http-get://localhost:18080/healthz http-get://localhost:18090/healthz http-get://localhost:18091/healthz && npm run dev -w client",
    "dev:api-acceptance": "./scripts/dev-api-acceptance.sh",
    "build": "npm run go:build && npm run build -w client && npm run build -w browser-extensions",
    "db:migrate": "./scripts/db-migrate.sh up",
    "typecheck": "npm run typecheck -w client && npm run typecheck -w browser-extensions",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "sast": "npm audit --audit-level=critical --audit-endpoint=https://registry.npmjs.org/-/npm/v1/security/advisories/bulk",
    "security": "./scripts/security-scan.sh",
    "security:quick": "./scripts/security-scan.sh --quick",
    "security:docker": "./scripts/security-scan.sh --docker",
    "codeql": "./scripts/codeql-scan.sh",
    "codeql:full": "./scripts/codeql-scan.sh --full",
    "test:watch": "npm run test:watch -w client",
    "verify": "npm run backend:generate && npm run go:test && npm run typecheck && npm run lint && npm run sast && npm run test -w client && npm run test -w browser-extensions && npm run build"
  },
  "overrides": {
    "hono": "4.12.8",
    "@hono/node-server": "1.19.11",
    "axios": "1.15.0",
    "basic-ftp": "5.2.2",
    "lodash": "4.18.1",
    "follow-redirects": "1.16.0",
    "tar-fs": ">=2.1.4",
    "targz": {
      "tar-fs": "1.16.6"
    },
    "tar-stream": ">=2.2.0",
    "serialize-javascript": ">=7.0.3",
    "dompurify": "$dompurify"
  },
  "devDependencies": {
    "@types/selenium-webdriver": "^4.35.5",
    "concurrently": "9.2.1",
    "eslint": "9.39.4",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "eslint-plugin-security": "4.0.0",
    "puppeteer": "^24.40.0",
    "selenium-webdriver": "^4.41.0",
    "typescript-eslint": "8.57.2",
    "vite": "^8.0.8",
    "wait-on": "9.0.4"
  },
  "dependencies": {
    "dompurify": "3.3.3"
  }
}
