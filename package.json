{
  "name": "arsenale",
  "version": "1.2.0",
  "description": "Web-based remote desktop manager for SSH and RDP connections with encrypted vault, team sharing, and multi-tenant support",
  "author": "Daniele Vitali <daniele@dnviti.dev>",
  "license": "BUSL-1.1",
  "homepage": "https://github.com/dnviti/arsenale",
  "repository": {
    "type": "git",
    "url": "https://github.com/dnviti/arsenale.git"
  },
  "bugs": {
    "url": "https://github.com/dnviti/arsenale/issues"
  },
  "keywords": [
    "remote-desktop",
    "ssh",
    "rdp",
    "guacamole",
    "web-terminal",
    "sftp",
    "xterm",
    "vault",
    "multi-tenant"
  ],
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "predev": "$(./scripts/container-runtime.sh) compose -f compose.dev.yml up -d --wait postgres && npm run db:generate",
    "db:push": "npm run db:push -w server",
    "dev": "concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client:wait\"",
    "dev:server": "npm run dev -w server",
    "dev:client": "npm run dev -w client",
    "dev:client:wait": "wait-on -t 60000 http-get://localhost:3001/api/health && npm run dev -w client",
    "dev:docker": "$(./scripts/container-runtime.sh) compose -f compose.dev.yml up --build",
    "dev:docker:detach": "$(./scripts/container-runtime.sh) compose -f compose.dev.yml up --build -d",
    "build": "npm run build -w server && npm run build -w client",
    "docker:dev": "$(./scripts/container-runtime.sh) compose -f compose.dev.yml up -d",
    "docker:dev:down": "$(./scripts/container-runtime.sh) compose -f compose.dev.yml down",
    "docker:prod": "$(./scripts/container-runtime.sh) compose --env-file .env.production up -d --build",
    "db:migrate": "npm run db:migrate -w server",
    "db:generate": "npm run db:generate -w server",
    "typecheck": "npm run typecheck -w server && npm run typecheck -w client",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "sast": "npm audit --audit-level=critical",
    "security": "./scripts/security-scan.sh",
    "security:quick": "./scripts/security-scan.sh --quick",
    "security:docker": "./scripts/security-scan.sh --docker",
    "verify": "npm run typecheck && npm run lint && npm run sast && npm run build"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "eslint": "^9.39.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-security": "^4.0.0",
    "typescript-eslint": "^8.56.1",
    "wait-on": "^9.0.4"
  }
}
