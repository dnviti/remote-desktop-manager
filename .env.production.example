# Production secrets — copy this file to .env.production and fill in real values
# NEVER commit .env.production to version control
# Generate secrets with: openssl rand -base64 32

# PostgreSQL
POSTGRES_USER=arsenale
POSTGRES_PASSWORD=<generate-a-strong-password>
POSTGRES_DB=arsenale

# JWT
JWT_SECRET=<generate-a-strong-secret>

# Guacamole encryption
GUACAMOLE_SECRET=<generate-a-strong-secret>

# Vault
VAULT_TTL_MINUTES=30
