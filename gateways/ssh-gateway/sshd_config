# Arsenale SSH Gateway — port-forwarding-only configuration
# No shell access, no root login, public key auth only
# Runs as non-root (tunnel user) for Podman rootless compatibility

Port 2222
PidFile /tmp/sshd.pid

HostKey /etc/ssh/ssh_host_ed25519_key
HostKey /etc/ssh/ssh_host_rsa_key

PermitRootLogin no
PasswordAuthentication no
PubkeyAuthentication yes
AuthorizedKeysFile /home/tunnel/.ssh/authorized_keys

AllowTcpForwarding yes
GatewayPorts no
X11Forwarding no
PermitTTY no
ForceCommand /sbin/nologin
AllowUsers tunnel

# Logging
SyslogFacility AUTH
LogLevel INFO

# Security hardening
MaxAuthTries 3
LoginGraceTime 30
ClientAliveInterval 60
ClientAliveCountMax 3
