generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TenantRole {
  OWNER
  ADMIN
  MEMBER
}

enum TeamRole {
  TEAM_ADMIN
  TEAM_EDITOR
  TEAM_VIEWER
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
  teams Team[]
}

model Team {
  id          String   @id @default(uuid())
  name        String
  description String?
  tenantId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant         @relation(fields: [tenantId], references: [id])
  members     TeamMember[]
  connections Connection[]
  folders     Folder[]

  @@unique([tenantId, name])
}

model TeamMember {
  id                    String   @id @default(uuid())
  teamId                String
  userId                String
  role                  TeamRole
  encryptedTeamVaultKey String?
  teamVaultKeyIV        String?
  teamVaultKeyTag       String?
  joinedAt              DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model User {
  id                 String      @id @default(uuid())
  email              String      @unique
  username           String?
  avatarData         String?
  passwordHash       String?
  vaultSalt          String?
  encryptedVaultKey  String?
  vaultKeyIV         String?
  vaultKeyTag        String?
  vaultSetupComplete Boolean     @default(true)
  sshDefaults        Json?
  rdpDefaults        Json?
  totpSecret         String?
  totpEnabled        Boolean     @default(false)
  emailVerified      Boolean     @default(false)
  emailVerifyToken   String?     @unique
  emailVerifyExpiry  DateTime?
  tenantId           String?
  tenantRole         TenantRole?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  tenant        Tenant?            @relation(fields: [tenantId], references: [id])
  connections   Connection[]
  folders       Folder[]
  sharedWithMe  SharedConnection[] @relation("SharedWith")
  sharedByMe    SharedConnection[] @relation("SharedBy")
  refreshTokens RefreshToken[]
  oauthAccounts OAuthAccount[]
  auditLogs     AuditLog[]
  notifications Notification[]
  teamMembers   TeamMember[]
}

enum AuthProvider {
  LOCAL
  GOOGLE
  MICROSOFT
  GITHUB
}

model OAuthAccount {
  id             String       @id @default(uuid())
  userId         String
  provider       AuthProvider
  providerUserId String
  providerEmail  String?
  accessToken    String?
  refreshToken   String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
}

model Folder {
  id        String   @id @default(uuid())
  name      String
  parentId  String?
  userId    String
  teamId    String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent      Folder?      @relation("FolderTree", fields: [parentId], references: [id])
  children    Folder[]     @relation("FolderTree")
  user        User         @relation(fields: [userId], references: [id])
  team        Team?        @relation(fields: [teamId], references: [id])
  connections Connection[]
}

model Connection {
  id                String         @id @default(uuid())
  name              String
  type              ConnectionType
  host              String
  port              Int
  folderId          String?
  teamId            String?
  encryptedUsername  String
  usernameIV        String
  usernameTag       String
  encryptedPassword String
  passwordIV        String
  passwordTag       String
  description       String?
  isFavorite        Boolean        @default(false)
  enableDrive       Boolean        @default(false)
  sshTerminalConfig Json?
  rdpSettings       Json?
  userId            String
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  folder Folder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  team   Team?   @relation(fields: [teamId], references: [id])
  user   User    @relation(fields: [userId], references: [id])
  shares SharedConnection[]
}

enum ConnectionType {
  RDP
  SSH
}

model SharedConnection {
  id               String     @id @default(uuid())
  connectionId     String
  sharedWithUserId String
  sharedByUserId   String
  permission       Permission
  encryptedUsername String?
  usernameIV       String?
  usernameTag      String?
  encryptedPassword String?
  passwordIV       String?
  passwordTag      String?
  createdAt        DateTime   @default(now())

  connection Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  sharedWith User       @relation("SharedWith", fields: [sharedWithUserId], references: [id])
  sharedBy   User       @relation("SharedBy", fields: [sharedByUserId], references: [id])

  @@unique([connectionId, sharedWithUserId])
}

enum Permission {
  READ_ONLY
  FULL_ACCESS
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum AuditAction {
  LOGIN
  LOGIN_OAUTH
  LOGIN_TOTP
  LOGOUT
  REGISTER
  VAULT_UNLOCK
  VAULT_LOCK
  VAULT_SETUP
  CREATE_CONNECTION
  UPDATE_CONNECTION
  DELETE_CONNECTION
  SHARE_CONNECTION
  UNSHARE_CONNECTION
  UPDATE_SHARE_PERMISSION
  CREATE_FOLDER
  UPDATE_FOLDER
  DELETE_FOLDER
  PASSWORD_CHANGE
  PROFILE_UPDATE
  TOTP_ENABLE
  TOTP_DISABLE
  OAUTH_LINK
  OAUTH_UNLINK
  PASSWORD_REVEAL
  TENANT_CREATE
  TENANT_UPDATE
  TENANT_DELETE
  TENANT_INVITE_USER
  TENANT_REMOVE_USER
  TENANT_UPDATE_USER_ROLE
}

model AuditLog {
  id         String      @id @default(uuid())
  userId     String
  action     AuditAction
  targetType String?
  targetId   String?
  details    Json?
  ipAddress  String?
  createdAt  DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

enum NotificationType {
  CONNECTION_SHARED
  SHARE_PERMISSION_UPDATED
  SHARE_REVOKED
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  message   String
  read      Boolean          @default(false)
  relatedId String?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}
