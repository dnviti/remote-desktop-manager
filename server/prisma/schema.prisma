generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TenantRole {
  OWNER
  ADMIN
  MEMBER
}

enum TeamRole {
  TEAM_ADMIN
  TEAM_EDITOR
  TEAM_VIEWER
}

model Tenant {
  id                 String   @id @default(uuid())
  name               String
  slug               String   @unique
  hasTenantVaultKey  Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  users              User[]
  teams              Team[]
  gateways           Gateway[]
  sshKeyPair         SshKeyPair?
  vaultSecrets       VaultSecret[]
  tenantVaultMembers TenantVaultMember[]
}

model Team {
  id          String   @id @default(uuid())
  name        String
  description String?
  tenantId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant       Tenant         @relation(fields: [tenantId], references: [id])
  members      TeamMember[]
  connections  Connection[]
  folders      Folder[]
  vaultSecrets VaultSecret[]
  vaultFolders VaultFolder[]

  @@unique([tenantId, name])
}

model TeamMember {
  id                    String   @id @default(uuid())
  teamId                String
  userId                String
  role                  TeamRole
  encryptedTeamVaultKey String?
  teamVaultKeyIV        String?
  teamVaultKeyTag       String?
  joinedAt              DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model User {
  id                 String      @id @default(uuid())
  email              String      @unique
  username           String?
  avatarData         String?
  passwordHash       String?
  vaultSalt          String?
  encryptedVaultKey  String?
  vaultKeyIV         String?
  vaultKeyTag        String?
  vaultSetupComplete Boolean     @default(true)
  sshDefaults        Json?
  rdpDefaults        Json?
  totpSecret         String?
  totpEnabled        Boolean     @default(false)
  phoneNumber        String?
  phoneVerified      Boolean     @default(false)
  smsMfaEnabled      Boolean     @default(false)
  smsOtpHash         String?
  smsOtpExpiresAt    DateTime?
  emailVerified      Boolean     @default(false)
  emailVerifyToken   String?     @unique
  emailVerifyExpiry  DateTime?
  failedLoginAttempts Int         @default(0)
  lockedUntil         DateTime?
  tenantId           String?
  tenantRole         TenantRole?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  tenant        Tenant?            @relation(fields: [tenantId], references: [id])
  connections   Connection[]
  folders       Folder[]
  sharedWithMe  SharedConnection[] @relation("SharedWith")
  sharedByMe    SharedConnection[] @relation("SharedBy")
  refreshTokens RefreshToken[]
  oauthAccounts OAuthAccount[]
  auditLogs     AuditLog[]
  notifications Notification[]
  teamMembers            TeamMember[]
  gatewaysCreated        Gateway[]              @relation("GatewayCreator")
  openTabs               OpenTab[]
  vaultSecrets           VaultSecret[]          @relation("VaultSecretOwner")
  secretVersionChanges   VaultSecretVersion[]   @relation("SecretVersionChanger")
  vaultFolders           VaultFolder[]
  tenantVaultMemberships TenantVaultMember[]
  secretsSharedWithMe    SharedSecret[]         @relation("SecretSharedWith")
  secretsSharedByMe      SharedSecret[]         @relation("SecretSharedBy")
}

enum AuthProvider {
  LOCAL
  GOOGLE
  MICROSOFT
  GITHUB
  OIDC
}

model OAuthAccount {
  id             String       @id @default(uuid())
  userId         String
  provider       AuthProvider
  providerUserId String
  providerEmail  String?
  accessToken    String?
  refreshToken   String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
}

model Folder {
  id        String   @id @default(uuid())
  name      String
  parentId  String?
  userId    String
  teamId    String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent      Folder?      @relation("FolderTree", fields: [parentId], references: [id])
  children    Folder[]     @relation("FolderTree")
  user        User         @relation(fields: [userId], references: [id])
  team        Team?        @relation(fields: [teamId], references: [id])
  connections Connection[]
}

model Connection {
  id                String         @id @default(uuid())
  name              String
  type              ConnectionType
  host              String
  port              Int
  folderId          String?
  teamId            String?
  encryptedUsername  String?
  usernameIV        String?
  usernameTag       String?
  encryptedPassword String?
  passwordIV        String?
  passwordTag       String?
  credentialSecretId String?
  description       String?
  isFavorite        Boolean        @default(false)
  enableDrive       Boolean        @default(false)
  sshTerminalConfig Json?
  rdpSettings       Json?
  userId            String
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  gatewayId         String?

  folder           Folder?       @relation(fields: [folderId], references: [id], onDelete: SetNull)
  team             Team?         @relation(fields: [teamId], references: [id])
  user             User          @relation(fields: [userId], references: [id])
  gateway          Gateway?      @relation(fields: [gatewayId], references: [id], onDelete: SetNull)
  credentialSecret VaultSecret?  @relation(fields: [credentialSecretId], references: [id], onDelete: SetNull)
  shares           SharedConnection[]
  openTabs         OpenTab[]
}

enum ConnectionType {
  RDP
  SSH
}

enum GatewayType {
  GUACD
  SSH_BASTION
  MANAGED_SSH
}

enum GatewayHealthStatus {
  UNKNOWN
  REACHABLE
  UNREACHABLE
}

model Gateway {
  id          String      @id @default(uuid())
  name        String
  type        GatewayType
  host        String
  port        Int
  description String?
  isDefault   Boolean     @default(false)
  tenantId    String
  createdById String

  encryptedUsername  String?
  usernameIV         String?
  usernameTag        String?
  encryptedPassword  String?
  passwordIV         String?
  passwordTag        String?
  encryptedSshKey    String?
  sshKeyIV           String?
  sshKeyTag          String?
  apiPort            Int?

  monitoringEnabled   Boolean             @default(true)
  monitorIntervalMs   Int                 @default(5000)
  lastHealthStatus    GatewayHealthStatus @default(UNKNOWN)
  lastCheckedAt       DateTime?
  lastLatencyMs       Int?
  lastError           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  createdBy   User         @relation("GatewayCreator", fields: [createdById], references: [id])
  connections Connection[]

  @@index([tenantId])
  @@index([tenantId, type, isDefault])
}

model SshKeyPair {
  id                  String   @id @default(uuid())
  tenantId            String   @unique
  encryptedPrivateKey String
  privateKeyIV        String
  privateKeyTag       String
  publicKey           String
  fingerprint         String
  algorithm            String    @default("ed25519")
  expiresAt            DateTime?
  autoRotateEnabled    Boolean   @default(false)
  rotationIntervalDays Int       @default(90)
  lastAutoRotatedAt    DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model SharedConnection {
  id               String     @id @default(uuid())
  connectionId     String
  sharedWithUserId String
  sharedByUserId   String
  permission       Permission
  encryptedUsername String?
  usernameIV       String?
  usernameTag      String?
  encryptedPassword String?
  passwordIV       String?
  passwordTag      String?
  createdAt        DateTime   @default(now())

  connection Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  sharedWith User       @relation("SharedWith", fields: [sharedWithUserId], references: [id])
  sharedBy   User       @relation("SharedBy", fields: [sharedByUserId], references: [id])

  @@unique([connectionId, sharedWithUserId])
}

enum Permission {
  READ_ONLY
  FULL_ACCESS
}

enum SecretType {
  LOGIN
  SSH_KEY
  CERTIFICATE
  API_KEY
  SECURE_NOTE
}

enum SecretScope {
  PERSONAL
  TEAM
  TENANT
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum AuditAction {
  LOGIN
  LOGIN_OAUTH
  LOGIN_TOTP
  LOGIN_FAILURE
  LOGOUT
  REGISTER
  VAULT_UNLOCK
  VAULT_LOCK
  VAULT_SETUP
  CREATE_CONNECTION
  UPDATE_CONNECTION
  DELETE_CONNECTION
  SHARE_CONNECTION
  UNSHARE_CONNECTION
  UPDATE_SHARE_PERMISSION
  CREATE_FOLDER
  UPDATE_FOLDER
  DELETE_FOLDER
  PASSWORD_CHANGE
  PROFILE_UPDATE
  TOTP_ENABLE
  TOTP_DISABLE
  LOGIN_SMS
  SMS_MFA_ENABLE
  SMS_MFA_DISABLE
  SMS_PHONE_VERIFY
  OAUTH_LINK
  OAUTH_UNLINK
  PASSWORD_REVEAL
  TENANT_CREATE
  TENANT_UPDATE
  TENANT_DELETE
  TENANT_INVITE_USER
  TENANT_REMOVE_USER
  TENANT_UPDATE_USER_ROLE
  TEAM_CREATE
  TEAM_UPDATE
  TEAM_DELETE
  TEAM_ADD_MEMBER
  TEAM_REMOVE_MEMBER
  TEAM_UPDATE_MEMBER_ROLE
  EMAIL_TEST_SEND
  GATEWAY_CREATE
  GATEWAY_UPDATE
  GATEWAY_DELETE
  SSH_KEY_GENERATE
  SSH_KEY_ROTATE
  SSH_KEY_PUSH
  SSH_KEY_AUTO_ROTATE
  BATCH_SHARE
  SESSION_START
  SESSION_END
  SECRET_CREATE
  SECRET_READ
  SECRET_UPDATE
  SECRET_DELETE
  SECRET_SHARE
  SECRET_UNSHARE
  SECRET_EXTERNAL_SHARE
  SECRET_EXTERNAL_ACCESS
  SECRET_VERSION_RESTORE
  TENANT_VAULT_INIT
  TENANT_VAULT_KEY_DISTRIBUTE
}

model AuditLog {
  id         String      @id @default(uuid())
  userId     String?
  action     AuditAction
  targetType String?
  targetId   String?
  details    Json?
  ipAddress  String?
  createdAt  DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

enum NotificationType {
  CONNECTION_SHARED
  SHARE_PERMISSION_UPDATED
  SHARE_REVOKED
  SECRET_SHARED
  SECRET_SHARE_REVOKED
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  message   String
  read      Boolean          @default(false)
  relatedId String?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

model OpenTab {
  id           String     @id @default(uuid())
  userId       String
  connectionId String
  sortOrder    Int        @default(0)
  isActive     Boolean    @default(false)
  createdAt    DateTime   @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([userId, connectionId])
  @@index([userId])
}

model VaultSecret {
  id             String      @id @default(uuid())
  name           String
  description    String?
  type           SecretType
  scope          SecretScope
  userId         String
  teamId         String?
  tenantId       String?
  folderId       String?
  encryptedData  String
  dataIV         String
  dataTag        String
  metadata       Json?
  tags           String[]    @default([])
  isFavorite     Boolean     @default(false)
  expiresAt      DateTime?
  currentVersion Int         @default(1)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user        User               @relation("VaultSecretOwner", fields: [userId], references: [id])
  team        Team?              @relation(fields: [teamId], references: [id])
  tenant      Tenant?            @relation(fields: [tenantId], references: [id])
  folder      VaultFolder?       @relation(fields: [folderId], references: [id], onDelete: SetNull)
  versions    VaultSecretVersion[]
  shares      SharedSecret[]
  connections Connection[]

  @@index([userId, scope])
  @@index([teamId])
  @@index([tenantId, scope])
  @@index([expiresAt])
}

model VaultSecretVersion {
  id            String   @id @default(uuid())
  secretId      String
  version       Int
  encryptedData String
  dataIV        String
  dataTag       String
  changedBy     String
  changeNote    String?
  createdAt     DateTime @default(now())

  secret  VaultSecret @relation(fields: [secretId], references: [id], onDelete: Cascade)
  changer User        @relation("SecretVersionChanger", fields: [changedBy], references: [id])

  @@unique([secretId, version])
  @@index([secretId])
}

model SharedSecret {
  id               String     @id @default(uuid())
  secretId         String
  sharedWithUserId String
  sharedByUserId   String
  permission       Permission
  encryptedData    String
  dataIV           String
  dataTag          String
  createdAt        DateTime   @default(now())

  secret    VaultSecret @relation(fields: [secretId], references: [id], onDelete: Cascade)
  sharedWith User       @relation("SecretSharedWith", fields: [sharedWithUserId], references: [id])
  sharedBy   User       @relation("SecretSharedBy", fields: [sharedByUserId], references: [id])

  @@unique([secretId, sharedWithUserId])
}

model VaultFolder {
  id        String      @id @default(uuid())
  name      String
  parentId  String?
  userId    String
  scope     SecretScope
  teamId    String?
  tenantId  String?
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  parent   VaultFolder?  @relation("VaultFolderTree", fields: [parentId], references: [id])
  children VaultFolder[] @relation("VaultFolderTree")
  user     User          @relation(fields: [userId], references: [id])
  team     Team?         @relation(fields: [teamId], references: [id])
  secrets  VaultSecret[]

  @@index([userId, scope])
  @@index([teamId])
  @@index([tenantId])
}

model TenantVaultMember {
  id                      String   @id @default(uuid())
  tenantId                String
  userId                  String
  encryptedTenantVaultKey String
  tenantVaultKeyIV        String
  tenantVaultKeyTag       String
  createdAt               DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
}
