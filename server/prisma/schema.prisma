  TENANT_DLP_POLICY_UPDATE
  TENANT_CONNECTION_POLICY_UPDATE
  TOKEN_HIJACK_ATTEMPT
  SESSION_LIMIT_EXCEEDED
  SESSION_ABSOLUTE_TIMEOUT
  VAULT_PROVIDER_CREATE
  VAULT_PROVIDER_UPDATE
