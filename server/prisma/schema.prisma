  VAULT_UNLOCK
  VAULT_LOCK
  VAULT_SETUP
  CREATE_CONNECTION
  UPDATE_CONNECTION
  DELETE_CONNECTION
  SHARE_CONNECTION
  UNSHARE_CONNECTION
  UPDATE_SHARE_PERMISSION
  CREATE_FOLDER
  UPDATE_FOLDER
  DELETE_FOLDER
  PASSWORD_CHANGE
  PROFILE_UPDATE
  TOTP_ENABLE
  TOTP_DISABLE
  LOGIN_SMS
  SMS_MFA_ENABLE
  SMS_MFA_DISABLE
  SMS_PHONE_VERIFY
  OAUTH_LINK
  OAUTH_UNLINK
  PASSWORD_REVEAL
  TENANT_CREATE
  TENANT_UPDATE
  TENANT_DELETE
  TENANT_INVITE_USER
  TENANT_REMOVE_USER
  TENANT_UPDATE_USER_ROLE
  TEAM_CREATE
  TEAM_UPDATE
  TEAM_DELETE
  TEAM_ADD_MEMBER
  TEAM_REMOVE_MEMBER
  TEAM_UPDATE_MEMBER_ROLE
  EMAIL_TEST_SEND
  GATEWAY_CREATE
  GATEWAY_UPDATE
  GATEWAY_DELETE
  SSH_KEY_GENERATE
