generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum TenantRole {
  OWNER
  ADMIN
  OPERATOR
  MEMBER
  CONSULTANT
  AUDITOR
  GUEST
}

enum TeamRole {
  TEAM_ADMIN
  TEAM_EDITOR
  TEAM_VIEWER
}

model Tenant {
  id                 String   @id @default(uuid())
  name               String
  slug               String   @unique
  hasTenantVaultKey            Boolean  @default(false)
  mfaRequired                  Boolean  @default(false)
  vaultAutoLockMaxMinutes      Int?
  defaultSessionTimeoutSeconds Int      @default(3600)
  maxConcurrentSessions        Int      @default(0)
  absoluteSessionTimeoutSeconds Int     @default(43200)
  dlpDisableCopy               Boolean  @default(false)
  dlpDisablePaste              Boolean  @default(false)
  dlpDisableDownload           Boolean  @default(false)
  dlpDisableUpload             Boolean  @default(false)
  enforcedConnectionSettings   Json?
  ipAllowlistEnabled           Boolean  @default(false)
  ipAllowlistMode              String   @default("flag")
  ipAllowlistEntries           String[] @default([])
  tunnelDefaultEnabled         Boolean  @default(false)
  tunnelAutoTokenRotation      Boolean  @default(false)
  tunnelTokenRotationDays      Int      @default(90)
  tunnelRequireForRemote       Boolean  @default(false)
  tunnelTokenMaxLifetimeDays   Int?
  tunnelAgentAllowedCidrs      String[] @default([])
  createdAt                    DateTime @default(now())
  updatedAt          DateTime @updatedAt

  members            TenantMember[]
  teams              Team[]
  gateways           Gateway[]
  gatewayTemplates   GatewayTemplate[]
  sshKeyPair         SshKeyPair?
  vaultSecrets       VaultSecret[]
  tenantVaultMembers TenantVaultMember[]
  syncProfiles       SyncProfile[]
  externalVaultProviders ExternalVaultProvider[]
}

model Team {
  id          String   @id @default(uuid())
  name        String
  description String?
  tenantId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant       Tenant         @relation(fields: [tenantId], references: [id])
  members      TeamMember[]
  connections  Connection[]
  folders      Folder[]
  vaultSecrets VaultSecret[]
  vaultFolders VaultFolder[]
  syncProfiles SyncProfile[]

  @@unique([tenantId, name])
}

model TeamMember {
  id                    String   @id @default(uuid())
  teamId                String
  userId                String
  role                  TeamRole
  encryptedTeamVaultKey String?
  teamVaultKeyIV        String?
  teamVaultKeyTag       String?
  joinedAt              DateTime @default(now())
  expiresAt             DateTime?

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([expiresAt])
}

model User {
  id                 String      @id @default(uuid())
  email              String      @unique
  username           String?
  avatarData         String?
  passwordHash       String?
  vaultSalt          String?
  encryptedVaultKey  String?
  vaultKeyIV         String?
  vaultKeyTag        String?
  vaultSetupComplete Boolean     @default(true)
  sshDefaults        Json?
  rdpDefaults        Json?
  totpSecret          String?
  encryptedTotpSecret String?
  totpSecretIV        String?
  totpSecretTag       String?
  totpEnabled         Boolean     @default(false)
  phoneNumber        String?
  phoneVerified      Boolean     @default(false)
  smsMfaEnabled      Boolean     @default(false)
  smsOtpHash         String?
  smsOtpExpiresAt    DateTime?
  webauthnEnabled    Boolean     @default(false)
  vaultAutoLockMinutes Int?
  notifDndEnabled          Boolean  @default(false)
  notifQuietHoursStart     String?
  notifQuietHoursEnd       String?
  notifQuietHoursTimezone  String?
  domainName               String?
  domainUsername           String?
  encryptedDomainPassword  String?
  domainPasswordIV         String?
  domainPasswordTag        String?
  enabled            Boolean     @default(true)
  emailVerified              Boolean     @default(false)
  emailVerifyToken           String?     @unique
  emailVerifyExpiry          DateTime?
  pendingEmail               String?
  emailChangeCodeOldHash     String?
  emailChangeCodeNewHash     String?
  emailChangeExpiry          DateTime?
  passwordResetTokenHash     String?   @unique
  passwordResetExpiry        DateTime?
  encryptedVaultRecoveryKey  String?
  vaultRecoveryKeyIV         String?
  vaultRecoveryKeyTag        String?
  vaultRecoveryKeySalt       String?
  failedLoginAttempts Int         @default(0)
  lockedUntil         DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  tenantMemberships  TenantMember[]
  connections   Connection[]
  folders       Folder[]
  sharedWithMe  SharedConnection[] @relation("SharedWith")
  sharedByMe    SharedConnection[] @relation("SharedBy")
  refreshTokens RefreshToken[]
  oauthAccounts OAuthAccount[]
  auditLogs     AuditLog[]
  notifications            Notification[]
  notificationPreferences NotificationPreference[]
  teamMembers            TeamMember[]
  gatewaysCreated        Gateway[]              @relation("GatewayCreator")
  gatewayTemplatesCreated GatewayTemplate[]     @relation("GatewayTemplateCreator")
  openTabs               OpenTab[]
  vaultSecrets           VaultSecret[]          @relation("VaultSecretOwner")
  secretVersionChanges   VaultSecretVersion[]   @relation("SecretVersionChanger")
  vaultFolders           VaultFolder[]
  tenantVaultMemberships TenantVaultMember[]
  secretsSharedWithMe    SharedSecret[]         @relation("SecretSharedWith")
  secretsSharedByMe      SharedSecret[]         @relation("SecretSharedBy")
  externalSecretShares   ExternalSecretShare[]
  activeSessions         ActiveSession[]
  webauthnCredentials    WebAuthnCredential[]
  sessionRecordings      SessionRecording[]
  syncProfilesCreated    SyncProfile[]          @relation("SyncProfileCreator")
  dbAuditLogs            DbAuditLog[]
}

enum AuthProvider {
  LOCAL
  GOOGLE
  MICROSOFT
  GITHUB
  OIDC
  SAML
  LDAP
}

model OAuthAccount {
  id             String       @id @default(uuid())
  userId         String
  provider       AuthProvider
  providerUserId String
  providerEmail  String?
  accessToken    String?
  refreshToken   String?
  samlAttributes Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
}

model Folder {
  id        String   @id @default(uuid())
  name      String
  parentId  String?
  userId    String
  teamId    String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent      Folder?      @relation("FolderTree", fields: [parentId], references: [id])
  children    Folder[]     @relation("FolderTree")
  user        User         @relation(fields: [userId], references: [id])
  team        Team?        @relation(fields: [teamId], references: [id])
  connections Connection[]
}

model Connection {
  id                String         @id @default(uuid())
  name              String
  type              ConnectionType
  host              String
  port              Int
  folderId          String?
  teamId            String?
  encryptedUsername  String?
  usernameIV        String?
  usernameTag       String?
  encryptedPassword String?
  passwordIV        String?
  passwordTag       String?
  encryptedDomain   String?
  domainIV          String?
  domainTag         String?
  credentialSecretId String?
  description       String?
  isFavorite        Boolean        @default(false)
  enableDrive       Boolean        @default(false)
  sshTerminalConfig Json?
  rdpSettings       Json?
  vncSettings       Json?
  dbSettings        Json?
  dlpPolicy         Json?
  defaultCredentialMode String?
  userId            String
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  gatewayId                 String?
  syncProfileId             String?
  externalId                String?
  externalVaultProviderId   String?
  externalVaultPath         String?

  // DB_TUNNEL fields — bastion connection, target database host/port, and DB type
  bastionConnectionId       String?
  targetDbHost              String?
  targetDbPort              Int?
  dbType                    String?

  folder           Folder?                @relation(fields: [folderId], references: [id], onDelete: SetNull)
  team             Team?                  @relation(fields: [teamId], references: [id])
  user             User                   @relation(fields: [userId], references: [id])
  gateway          Gateway?               @relation(fields: [gatewayId], references: [id], onDelete: SetNull)
  credentialSecret VaultSecret?           @relation(fields: [credentialSecretId], references: [id], onDelete: SetNull)
  syncProfile      SyncProfile?           @relation(fields: [syncProfileId], references: [id], onDelete: SetNull)
  externalVaultProvider ExternalVaultProvider? @relation(fields: [externalVaultProviderId], references: [id], onDelete: SetNull)
  shares           SharedConnection[]
  openTabs         OpenTab[]
  activeSessions   ActiveSession[]
  sessionRecordings SessionRecording[]
  dbAuditLogs      DbAuditLog[]

  @@index([syncProfileId, externalId])
}

enum ConnectionType {
  RDP
  SSH
  VNC
  DATABASE
  DB_TUNNEL
}

enum GatewayType {
  GUACD
  SSH_BASTION
  MANAGED_SSH
  DB_PROXY
}

enum GatewayHealthStatus {
  UNKNOWN
  REACHABLE
  UNREACHABLE
}

enum SessionProtocol {
  SSH
  RDP
  VNC
  SSH_PROXY
  DATABASE
  DB_TUNNEL
}

enum SessionStatus {
  ACTIVE
  IDLE
  CLOSED
}

enum ManagedInstanceStatus {
  PROVISIONING
  RUNNING
  STOPPED
  ERROR
  REMOVING
}

enum LoadBalancingStrategy {
  ROUND_ROBIN
  LEAST_CONNECTIONS
}

model Gateway {
  id          String      @id @default(uuid())
  name        String
  type        GatewayType
  host        String
  port        Int
  description String?
  isDefault   Boolean     @default(false)
  tenantId    String
  createdById String

  encryptedUsername  String?
  usernameIV         String?
  usernameTag        String?
  encryptedPassword  String?
  passwordIV         String?
  passwordTag        String?
  encryptedSshKey    String?
  sshKeyIV           String?
  sshKeyTag          String?
  apiPort            Int?

  templateId       String?

  isManaged        Boolean @default(false)
  publishPorts     Boolean @default(false)
  lbStrategy       LoadBalancingStrategy @default(ROUND_ROBIN)
  desiredReplicas  Int     @default(1)

  autoScale                Boolean  @default(false)
  minReplicas              Int      @default(1)
  maxReplicas              Int      @default(5)
  sessionsPerInstance      Int      @default(10)
  scaleDownCooldownSeconds Int      @default(300)
  lastScaleAction          DateTime?

  inactivityTimeoutSeconds Int @default(3600)

  monitoringEnabled   Boolean             @default(true)
  monitorIntervalMs   Int                 @default(5000)
  lastHealthStatus    GatewayHealthStatus @default(UNKNOWN)
  lastCheckedAt       DateTime?
  lastLatencyMs       Int?
  lastError           String?

  // Zero-trust tunnel fields
  tunnelEnabled          Boolean   @default(false)
  encryptedTunnelToken   String?
  tunnelTokenIV          String?
  tunnelTokenTag         String?
  tunnelTokenHash        String?   @unique
  tunnelConnectedAt      DateTime?
  tunnelLastHeartbeat    DateTime?
  tunnelClientVersion    String?
  tunnelClientIp         String?
  tunnelCaCert           String?
  tunnelCaKey            String?
  tunnelCaKeyIV          String?
  tunnelCaKeyTag         String?
  tunnelClientCert       String?
  tunnelClientCertExp    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant           @relation(fields: [tenantId], references: [id])
  createdBy      User             @relation("GatewayCreator", fields: [createdById], references: [id])
  template       GatewayTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  connections        Connection[]
  activeSessions     ActiveSession[]
  managedInstances   ManagedGatewayInstance[]

  @@index([tenantId])
  @@index([tenantId, type, isDefault])
}

model GatewayTemplate {
  id                       String      @id @default(uuid())
  name                     String
  type                     GatewayType
  host                     String
  port                     Int
  description              String?
  apiPort                  Int?
  autoScale                Boolean     @default(false)
  minReplicas              Int         @default(1)
  maxReplicas              Int         @default(5)
  sessionsPerInstance      Int         @default(10)
  scaleDownCooldownSeconds Int         @default(300)
  monitoringEnabled        Boolean     @default(true)
  monitorIntervalMs        Int         @default(5000)
  inactivityTimeoutSeconds Int         @default(3600)
  publishPorts             Boolean     @default(false)
  lbStrategy               LoadBalancingStrategy @default(ROUND_ROBIN)
  tenantId                 String
  createdById              String
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  createdBy User      @relation("GatewayTemplateCreator", fields: [createdById], references: [id])
  gateways  Gateway[]

  @@index([tenantId])
}

model SshKeyPair {
  id                  String   @id @default(uuid())
  tenantId            String   @unique
  encryptedPrivateKey String
  privateKeyIV        String
  privateKeyTag       String
  publicKey           String
  fingerprint         String
  algorithm            String    @default("ed25519")
  expiresAt            DateTime?
  autoRotateEnabled    Boolean   @default(false)
  rotationIntervalDays Int       @default(90)
  lastAutoRotatedAt    DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model SharedConnection {
  id               String     @id @default(uuid())
  connectionId     String
  sharedWithUserId String
  sharedByUserId   String
  permission       Permission
  encryptedUsername String?
  usernameIV       String?
  usernameTag      String?
  encryptedPassword String?
  passwordIV       String?
  passwordTag      String?
  encryptedDomain  String?
  domainIV         String?
  domainTag        String?
  createdAt        DateTime   @default(now())

  connection Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  sharedWith User       @relation("SharedWith", fields: [sharedWithUserId], references: [id])
  sharedBy   User       @relation("SharedBy", fields: [sharedByUserId], references: [id])

  @@unique([connectionId, sharedWithUserId])
}

enum Permission {
  READ_ONLY
  FULL_ACCESS
}

enum SecretType {
  LOGIN
  SSH_KEY
  CERTIFICATE
  API_KEY
  SECURE_NOTE
}

enum SecretScope {
  PERSONAL
  TEAM
  TENANT
}

model RefreshToken {
  id          String    @id @default(uuid())
  token       String    @unique
  userId      String
  tokenFamily     String
  familyCreatedAt DateTime  @default(now())
  ipUaHash        String?
  revokedAt   DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenFamily])
  @@index([userId])
  @@index([userId, familyCreatedAt])
}

