  SSH_KEY_PUSH
  SSH_KEY_AUTO_ROTATE
  GATEWAY_DEPLOY
  GATEWAY_UNDEPLOY
  GATEWAY_SCALE
  GATEWAY_SCALE_UP
  GATEWAY_SCALE_DOWN
  GATEWAY_RESTART
  GATEWAY_VIEW_LOGS
  GATEWAY_HEALTH_CHECK
  BATCH_SHARE
  SESSION_START
  SESSION_END
  SESSION_TIMEOUT
  SESSION_ERROR
  SECRET_CREATE
  SECRET_READ
