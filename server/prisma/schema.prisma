model AuditLog {
  id         String      @id @default(uuid())
  userId     String?
  action     AuditAction
  targetType String?
  targetId   String?
  details    Json?
  ipAddress  String?
  gatewayId  String?
  geoCountry String?
  geoCity    String?
  geoCoords  Float[]     @default([])
  flags      String[]    @default([])
  createdAt  DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([gatewayId])
  @@index([targetId, createdAt])
  @@index([geoCountry])
  @@index([userId, action, createdAt])
}

enum NotificationType {
  CONNECTION_SHARED
  SHARE_PERMISSION_UPDATED
  SHARE_REVOKED
  SECRET_SHARED
  SECRET_SHARE_REVOKED
  SECRET_EXPIRING
  SECRET_EXPIRED
  TENANT_INVITATION
  RECORDING_READY
  IMPOSSIBLE_TRAVEL_DETECTED
  LATERAL_MOVEMENT_ALERT
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  message   String
  read      Boolean          @default(false)
  relatedId String?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

model NotificationPreference {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  inApp     Boolean          @default(true)
  email     Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
}

model OpenTab {
  id           String     @id @default(uuid())
  userId       String
  connectionId String
  sortOrder    Int        @default(0)
  isActive     Boolean    @default(false)
  createdAt    DateTime   @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([userId, connectionId])
  @@index([userId])
}

model VaultSecret {
  id             String      @id @default(uuid())
  name           String
  description    String?
  type           SecretType
  scope          SecretScope
  userId         String
  teamId         String?
  tenantId       String?
  folderId       String?
  encryptedData  String
  dataIV         String
  dataTag        String
  metadata       Json?
  tags           String[]    @default([])
  isFavorite     Boolean     @default(false)
  pwnedCount     Int         @default(0)
  expiresAt      DateTime?
  currentVersion Int         @default(1)
  targetRotationEnabled  Boolean   @default(false)
  rotationIntervalDays   Int       @default(30)
  lastRotatedAt          DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user        User               @relation("VaultSecretOwner", fields: [userId], references: [id])
  team        Team?              @relation(fields: [teamId], references: [id])
  tenant      Tenant?            @relation(fields: [tenantId], references: [id])
  folder      VaultFolder?       @relation(fields: [folderId], references: [id], onDelete: SetNull)
  versions       VaultSecretVersion[]
  shares         SharedSecret[]
  externalShares ExternalSecretShare[]
  connections    Connection[]
  rotationLogs   PasswordRotationLog[]

  @@index([userId, scope])
  @@index([teamId])
  @@index([tenantId, scope])
  @@index([expiresAt])
  @@index([expiresAt, userId])
  @@index([targetRotationEnabled, lastRotatedAt])
}

model VaultSecretVersion {
  id            String   @id @default(uuid())
  secretId      String
  version       Int
  encryptedData String
  dataIV        String
  dataTag       String
  changedBy     String
  changeNote    String?
  createdAt     DateTime @default(now())

  secret  VaultSecret @relation(fields: [secretId], references: [id], onDelete: Cascade)
  changer User        @relation("SecretVersionChanger", fields: [changedBy], references: [id])

  @@unique([secretId, version])
  @@index([secretId])
}

model SharedSecret {
  id               String     @id @default(uuid())
  secretId         String
  sharedWithUserId String
  sharedByUserId   String
  permission       Permission
  encryptedData    String
  dataIV           String
  dataTag          String
  createdAt        DateTime   @default(now())

  secret    VaultSecret @relation(fields: [secretId], references: [id], onDelete: Cascade)
  sharedWith User       @relation("SecretSharedWith", fields: [sharedWithUserId], references: [id])
  sharedBy   User       @relation("SecretSharedBy", fields: [sharedByUserId], references: [id])

  @@unique([secretId, sharedWithUserId])
}

model VaultFolder {
  id        String      @id @default(uuid())
  name      String
  parentId  String?
  userId    String
  scope     SecretScope
  teamId    String?
  tenantId  String?
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  parent   VaultFolder?  @relation("VaultFolderTree", fields: [parentId], references: [id])
  children VaultFolder[] @relation("VaultFolderTree")
  user     User          @relation(fields: [userId], references: [id])
  team     Team?         @relation(fields: [teamId], references: [id])
  secrets  VaultSecret[]

  @@index([userId, scope])
  @@index([teamId])
  @@index([tenantId])
}

model TenantMember {
  id        String     @id @default(uuid())
  tenantId  String
  userId    String
  role      TenantRole @default(MEMBER)
  isActive  Boolean    @default(false)
  joinedAt  DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  expiresAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId, isActive])
  @@index([tenantId, isActive])
  @@index([expiresAt])
}

model TenantVaultMember {
  id                      String   @id @default(uuid())
  tenantId                String
  userId                  String
  encryptedTenantVaultKey String
  tenantVaultKeyIV        String
  tenantVaultKeyTag       String
  createdAt               DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
}

model ExternalSecretShare {
  id              String     @id @default(uuid())
  secretId        String
  createdByUserId String
  tokenHash       String     @unique
  encryptedData   String
  dataIV          String
  dataTag         String
  hasPin          Boolean    @default(false)
  pinSalt         String?
  tokenSalt       String?
  expiresAt       DateTime
  maxAccessCount  Int?
  accessCount     Int        @default(0)
  secretType      SecretType
  secretName      String
  isRevoked       Boolean    @default(false)
  createdAt       DateTime   @default(now())

  secret    VaultSecret @relation(fields: [secretId], references: [id], onDelete: Cascade)
  createdBy User        @relation(fields: [createdByUserId], references: [id])

  @@index([tokenHash])
  @@index([expiresAt])
}

model ActiveSession {
  id             String          @id @default(uuid())
  userId         String
  connectionId   String
  gatewayId      String?
  instanceId     String?
  protocol       SessionProtocol
  status         SessionStatus   @default(ACTIVE)
  socketId       String?
  guacTokenHash  String?
  ipAddress      String?
  startedAt      DateTime        @default(now())
  lastActivityAt DateTime        @default(now())
  endedAt        DateTime?
  metadata       Json?

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  gateway    Gateway?                @relation(fields: [gatewayId], references: [id], onDelete: SetNull)
  instance   ManagedGatewayInstance? @relation(fields: [instanceId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([status])
  @@index([gatewayId, status])
  @@index([protocol, status])
  @@index([lastActivityAt])
  @@index([socketId])
  @@index([guacTokenHash])
  @@index([instanceId, status])
}

model WebAuthnCredential {
  id           String    @id @default(uuid())
  userId       String
  credentialId String    @unique
  publicKey    String
  counter      BigInt    @default(0)
  transports   String[]  @default([])
  deviceType   String?
  backedUp     Boolean   @default(false)
  friendlyName String    @default("Security Key")
  aaguid       String?
  lastUsedAt   DateTime?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ManagedGatewayInstance {
  id               String                @id @default(uuid())
  gatewayId        String
  containerId      String                @unique
  containerName    String
  host             String
  port             Int
  apiPort          Int?
  status           ManagedInstanceStatus @default(PROVISIONING)
  orchestratorType String
  healthStatus     String?
  lastHealthCheck  DateTime?
  errorMessage         String?
  consecutiveFailures  Int               @default(0)
  tunnelProxyHost      String?
  tunnelProxyPort      Int?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  gateway          Gateway               @relation(fields: [gatewayId], references: [id], onDelete: Cascade)
  sessions         ActiveSession[]

  @@index([gatewayId])
  @@index([status])
}

model SessionRecording {
  id           String          @id @default(uuid())
  sessionId    String?
  userId       String
  connectionId String
  protocol     SessionProtocol
  filePath     String
  fileSize     Int?
  duration     Int?
  width        Int?
  height       Int?
  format       String          @default("asciicast")
  status       RecordingStatus @default(RECORDING)
  createdAt    DateTime        @default(now())
  completedAt  DateTime?

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([sessionId])
  @@index([connectionId])
}

enum RecordingStatus {
  RECORDING
  COMPLETE
  ERROR
}

enum ExternalVaultAuthMethod {
  TOKEN
  APPROLE
}

model ExternalVaultProvider {
  id                    String                   @id @default(uuid())
  tenantId              String
  name                  String
  serverUrl             String
  authMethod            ExternalVaultAuthMethod
  namespace             String?
  mountPath             String                   @default("secret")
  encryptedAuthPayload  String
  authPayloadIV         String
  authPayloadTag        String
  caCertificate         String?
  cacheTtlSeconds       Int                      @default(300)
  enabled               Boolean                  @default(true)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connections Connection[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

enum SyncProvider {
  NETBOX
}

enum SyncStatus {
  PENDING
  RUNNING
  SUCCESS
  PARTIAL
  ERROR
}

model SyncProfile {
  id                String        @id @default(uuid())
  name              String
  tenantId          String
  provider          SyncProvider
  config            Json
  encryptedApiToken String
  apiTokenIV        String
  apiTokenTag       String
  cronExpression    String?
  enabled           Boolean       @default(true)
  teamId            String?
  lastSyncAt        DateTime?
  lastSyncStatus    SyncStatus?
  lastSyncDetails   Json?
  createdById       String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy   User         @relation("SyncProfileCreator", fields: [createdById], references: [id])
  team        Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)
  connections Connection[]
  syncLogs    SyncLog[]

  @@index([tenantId])
  @@index([tenantId, provider])
}

model SyncLog {
  id            String     @id @default(uuid())
  syncProfileId String
  status        SyncStatus
  startedAt     DateTime   @default(now())
  completedAt   DateTime?
  details       Json?
  triggeredBy   String

  syncProfile SyncProfile @relation(fields: [syncProfileId], references: [id], onDelete: Cascade)

  @@index([syncProfileId, startedAt])
}

model AppConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

enum AccessPolicyTargetType {
  TENANT
  TEAM
  FOLDER
}

/// Attribute-Based Access Control (ABAC) policy.
/// Evaluated when a user attempts to start a session against a connection
/// that belongs to a target (Folder, Team, or Tenant).
model AccessPolicy {
  id                  String                 @id @default(uuid())
  targetType          AccessPolicyTargetType
  /// ID of the Folder, Team, or Tenant this policy governs
  targetId            String
  /// Comma-separated time windows in "HH:MM-HH:MM" format (local UTC).
  /// Example: "09:00-18:00" means sessions are only allowed between 09:00 and 18:00 UTC.
  /// Leave null to allow any time.
  allowedTimeWindows  String?
  /// When true, the user must have authenticated with a WebAuthn credential
  /// during the current login (trusted device check).
  requireTrustedDevice Boolean @default(false)
  /// When true, the user must have performed MFA step-up (TOTP or WebAuthn)
  /// in this login session.
  requireMfaStepUp    Boolean @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([targetType, targetId])
}

// ---- Database Query Auditing & SQL Firewall ----

enum DbQueryType {
  SELECT
  INSERT
  UPDATE
  DELETE
  DDL
  OTHER
}

/// Logs every SQL statement executed through the DB proxy gateway.
model DbAuditLog {
  id              String      @id @default(uuid())
  userId          String
  connectionId    String
  tenantId        String?
  queryText       String
  queryType       DbQueryType
  tablesAccessed  String[]    @default([])
  rowsAffected    Int?
  executionTimeMs Int?
  blocked         Boolean     @default(false)
  blockReason     String?
  createdAt       DateTime    @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([connectionId, createdAt])
  @@index([tenantId, createdAt])
  @@index([queryType])
  @@index([blocked])
}

enum FirewallAction {
  BLOCK
  ALERT
  LOG
}

/// Configurable SQL firewall rule evaluated against every query.
model DbFirewallRule {
  id          String         @id @default(uuid())
  tenantId    String
  name        String
  pattern     String
  action      FirewallAction
  scope       String?        /// Optional database or table name to limit scope
  description String?
  enabled     Boolean        @default(true)
  priority    Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([tenantId, enabled])
  @@index([tenantId])
}

enum MaskingStrategy {
  REDACT
  HASH
  PARTIAL
}

/// Column-level data masking policy applied at the proxy response layer.
model DbMaskingPolicy {
  id              String          @id @default(uuid())
  tenantId        String
  name            String
  columnPattern   String          /// Regex pattern matching column names
  strategy        MaskingStrategy
  exemptRoles     String[]        @default([])
  scope           String?         /// Optional database or table scope
  description     String?
  enabled         Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([tenantId, enabled])
  @@index([tenantId])
}

/// OAuth 2.0 Device Authorization Grant (RFC 8628).
/// Used by the CLI tool to authenticate via browser-based login.
model DeviceAuthCode {
  id             String    @id @default(uuid())
  deviceCode     String    @unique
  userCode       String    @unique
  /// Null until the user authorizes the device
  userId         String?
  authorized     Boolean   @default(false)
  expiresAt      DateTime
  interval       Int       @default(5)
  clientId       String    @default("arsenale-cli")
  createdAt      DateTime  @default(now())

  @@index([deviceCode])
  @@index([userCode])
}

enum RotationStatus {
  SUCCESS
  FAILED
  PENDING
}

enum RotationTrigger {
  SCHEDULED
  CHECKIN
  MANUAL
}

enum RotationTargetOS {
  LINUX
  WINDOWS
}

/// Tracks every password rotation attempt on a target system.
model PasswordRotationLog {
  id          String          @id @default(uuid())
  secretId    String
  status      RotationStatus
  trigger     RotationTrigger
  targetOS    RotationTargetOS
  targetHost  String
  targetUser  String
  errorMessage String?
  durationMs  Int?
  initiatedBy String?
  createdAt   DateTime        @default(now())

  secret VaultSecret @relation(fields: [secretId], references: [id], onDelete: Cascade)

  @@index([secretId, createdAt])
  @@index([status])
}
