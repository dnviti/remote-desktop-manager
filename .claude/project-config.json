    "batch_size": 64,
    "include_patterns": [],
    "exclude_patterns": []
  },
  "mcp_server": {
    "enabled": false,
    "transport": "stdio",
    "auto_start": false
  },
  "social_announce": {
    "platforms": {
      "bluesky": {
        "enabled": false
      },
      "mastodon": {
        "enabled": false
      },
      "discord": {
        "enabled": false
      },
      "slack": {
        "enabled": false
      }
    },
    "clipboard_platforms": [
      {
        "name": "twitter",
        "enabled": true,
        "max_length": 280,
