{
  "dev_ports": "3000,3001,3002",
  "start_command": "npm run dev",
  "predev_command": "npm run predev",
  "verify_command": "npm run verify",
  "test_framework": "vitest",
  "test_command": "",
  "test_file_pattern": "**/*.test.ts",
  "ci_runtime_setup": "",
  "tech_detail_layers": "",
