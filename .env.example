# Database (PostgreSQL — started by docker-compose.dev.yml)
DATABASE_URL=postgresql://rdm:rdm_password@127.0.0.1:5432/remote_desktop_manager

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Guacamole
GUACD_HOST=localhost
GUACD_PORT=4822
GUACAMOLE_SECRET=change-me-guacamole-secret

# Server
PORT=3001
GUACAMOLE_WS_PORT=3002
NODE_ENV=development

# Vault
VAULT_TTL_MINUTES=30

# Server encryption key (used to encrypt SSH key pairs for managed gateways)
# Required in production. 32 bytes in hex format (64 hex chars).
# Generate with:
#   Linux/macOS: openssl rand -hex 32
#   Node.js:     node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# In development, auto-generated on startup (not persisted across restarts).
SERVER_ENCRYPTION_KEY=

# Logging (error | warn | info | verbose | debug)
LOG_LEVEL=info
LOG_FORMAT=text              # Log output format (text | json)
LOG_TIMESTAMPS=true          # Include ISO-8601 timestamps in log output
LOG_HTTP_REQUESTS=false      # Log HTTP requests (method, url, status, duration)

# Drive redirection (file sharing)
DRIVE_BASE_PATH=./data/drive
FILE_UPLOAD_MAX_SIZE=10485760
USER_DRIVE_QUOTA=104857600

# Email verification enforcement (true|false — default: true)
# Set to false to allow login without verifying email
EMAIL_VERIFY_REQUIRED=true

# Email provider (smtp|sendgrid|ses|resend|mailgun — default: smtp)
# Leave EMAIL_PROVIDER unset or "smtp" with SMTP_HOST empty for dev mode
# (verification links logged to console)
EMAIL_PROVIDER=smtp

# SMTP (default provider)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# SendGrid (requires EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=

# Amazon SES (requires EMAIL_PROVIDER=ses)
# Leave access key empty to use IAM roles / default credential chain
AWS_SES_REGION=us-east-1
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=

# Resend (requires EMAIL_PROVIDER=resend)
RESEND_API_KEY=

# Mailgun (requires EMAIL_PROVIDER=mailgun)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_REGION=us

# SMS provider (twilio|sns|vonage — leave SMS_PROVIDER empty for dev mode)
# Dev mode logs OTP codes to console
SMS_PROVIDER=

# Twilio (requires SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# AWS SNS (requires SMS_PROVIDER=sns)
# Leave access key empty to use IAM roles / default credential chain
AWS_SNS_REGION=us-east-1
AWS_SNS_ACCESS_KEY_ID=
AWS_SNS_SECRET_ACCESS_KEY=

# Vonage (requires SMS_PROVIDER=vonage)
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_FROM_NUMBER=

# Client URL (used for email verification links and OAuth redirects)
CLIENT_URL=http://localhost:3000

# OAuth (leave CLIENT_ID empty to disable a provider)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_CALLBACK_URL=http://localhost:3001/api/auth/microsoft/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3001/api/auth/github/callback

# Generic OIDC provider (leave OIDC_CLIENT_ID empty to disable)
# Compatible with any OIDC-compliant IdP: Authentik, Keycloak, Authelia, Zitadel, etc.
OIDC_PROVIDER_NAME=SSO
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_CALLBACK_URL=http://localhost:3001/api/auth/oidc/callback
OIDC_SCOPES=openid profile email

# SSH Gateway (optional — managed SSH tunnel for port forwarding)
# Port exposed by the ssh-gateway container
SSH_GATEWAY_PORT=2222
# Public keys authorized to connect (newline-separated, or mount /config/authorized_keys)
SSH_AUTHORIZED_KEYS=

# SSH Gateway API (sidecar for automated key push)
# Shared secret token between RDM server and gateway container.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Leave empty to disable the sidecar API on the gateway container.
GATEWAY_API_TOKEN=

# SSH Key Rotation (automatic rotation of tenant SSH key pairs)
# Cron expression for the rotation check job (default: daily at 02:00 UTC)
KEY_ROTATION_CRON=0 2 * * *
# How many days before expiration to trigger rotation (default: 7)
KEY_ROTATION_ADVANCE_DAYS=7

# Login rate limiting & account lockout
# Sliding window duration in milliseconds (default: 15 minutes)
LOGIN_RATE_LIMIT_WINDOW_MS=900000
# Max login attempts per IP within the window (default: 5)
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
# Consecutive failed logins before account lockout (default: 10)
ACCOUNT_LOCKOUT_THRESHOLD=10
# Account lockout duration in milliseconds (default: 30 minutes)
ACCOUNT_LOCKOUT_DURATION_MS=1800000

# Container Orchestrator
# Provider type: docker | podman | kubernetes | none (leave empty for auto-detect)
ORCHESTRATOR_TYPE=
# Docker socket path (default: /var/run/docker.sock)
DOCKER_SOCKET_PATH=/var/run/docker.sock
# Podman socket path (default: $XDG_RUNTIME_DIR/podman/podman.sock for rootless,
# /run/podman/podman.sock for rootful). Only needed when ORCHESTRATOR_TYPE=podman.
# PODMAN_SOCKET_PATH=/run/user/1000/podman/podman.sock
# Container network for managed gateway containers (works with Docker and Podman).
# When using dev:docker mode (docker-compose.dev.yml), this is set to "rdm-dev"
# automatically via the compose environment overrides. Deployed gateways join this
# network so the server can reach them by container name (DNS).
# Leave empty for host-mode dev (containers use port mapping to localhost).
DOCKER_NETWORK=rdm-dev
# Kubernetes namespace for managed gateways (default: rdm).
# Per-tenant namespaces (rdm-{tenantId}) are auto-created during deployment.
ORCHESTRATOR_K8S_NAMESPACE=rdm
# Container images for managed gateways
ORCHESTRATOR_SSH_GATEWAY_IMAGE=ghcr.io/dnviti/remote-desktop-manager/ssh-gateway:latest
ORCHESTRATOR_GUACD_IMAGE=guacamole/guacd:latest

# WebAuthn / Passkey (FIDO2)
# Relying party identifier (usually the domain name, e.g., example.com)
WEBAUTHN_RP_ID=localhost
# Exact origin expected by the browser (scheme + domain + port)
WEBAUTHN_RP_ORIGIN=http://localhost:3000
# Human-readable name shown in browser/authenticator prompts
WEBAUTHN_RP_NAME=Remote Desktop Manager
