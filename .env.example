# Database (PostgreSQL — started by docker-compose.dev.yml)
DATABASE_URL=postgresql://rdm:rdm_password@127.0.0.1:5432/remote_desktop_manager

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Guacamole
GUACD_HOST=localhost
GUACD_PORT=4822
GUACAMOLE_SECRET=change-me-guacamole-secret

# Server
PORT=3001
GUACAMOLE_WS_PORT=3002
NODE_ENV=development

# Vault
VAULT_TTL_MINUTES=30

# Logging (error | warn | info | debug)
LOG_LEVEL=info

# Drive redirection (file sharing)
DRIVE_BASE_PATH=./data/drive
FILE_UPLOAD_MAX_SIZE=10485760
USER_DRIVE_QUOTA=104857600

# Email verification enforcement (true|false — default: true)
# Set to false to allow login without verifying email
EMAIL_VERIFY_REQUIRED=true

# Email provider (smtp|sendgrid|ses|resend|mailgun — default: smtp)
# Leave EMAIL_PROVIDER unset or "smtp" with SMTP_HOST empty for dev mode
# (verification links logged to console)
EMAIL_PROVIDER=smtp

# SMTP (default provider)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# SendGrid (requires EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=

# Amazon SES (requires EMAIL_PROVIDER=ses)
# Leave access key empty to use IAM roles / default credential chain
AWS_SES_REGION=us-east-1
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=

# Resend (requires EMAIL_PROVIDER=resend)
RESEND_API_KEY=

# Mailgun (requires EMAIL_PROVIDER=mailgun)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_REGION=us

# SMS provider (twilio|sns|vonage — leave SMS_PROVIDER empty for dev mode)
# Dev mode logs OTP codes to console
SMS_PROVIDER=

# Twilio (requires SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# AWS SNS (requires SMS_PROVIDER=sns)
# Leave access key empty to use IAM roles / default credential chain
AWS_SNS_REGION=us-east-1
AWS_SNS_ACCESS_KEY_ID=
AWS_SNS_SECRET_ACCESS_KEY=

# Vonage (requires SMS_PROVIDER=vonage)
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_FROM_NUMBER=

# Client URL (used for email verification links and OAuth redirects)
CLIENT_URL=http://localhost:3000

# OAuth (leave CLIENT_ID empty to disable a provider)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_CALLBACK_URL=http://localhost:3001/api/auth/microsoft/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3001/api/auth/github/callback

# Generic OIDC provider (leave OIDC_CLIENT_ID empty to disable)
# Compatible with any OIDC-compliant IdP: Authentik, Keycloak, Authelia, Zitadel, etc.
OIDC_PROVIDER_NAME=SSO
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_CALLBACK_URL=http://localhost:3001/api/auth/oidc/callback
OIDC_SCOPES=openid profile email
