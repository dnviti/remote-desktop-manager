# Database (SQLite per sviluppo, PostgreSQL per produzione)
DATABASE_URL=file:./dev.db
# DATABASE_URL=postgresql://rdm:rdm_password@localhost:5432/remote_desktop_manager

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Guacamole
GUACD_HOST=localhost
GUACD_PORT=4822
GUACAMOLE_SECRET=change-me-guacamole-secret

# Server
PORT=3001
GUACAMOLE_WS_PORT=3002
NODE_ENV=development

# Vault
VAULT_TTL_MINUTES=30
