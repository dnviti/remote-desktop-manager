# Arsenale Secrets — Source file for Ansible Vault generation
# Copy to SECRETS.env and fill in values, then run:
#   ./scripts/generate-vault.sh
#
# Required secrets are auto-generated if left empty.
# Optional secrets are only included in the vault if non-empty.

# =============================================================================
# REQUIRED — auto-generated with secure random values if left empty
# =============================================================================
JWT_SECRET=
GUACAMOLE_SECRET=
SERVER_ENCRYPTION_KEY=
POSTGRES_PASSWORD=
GUACENC_AUTH_TOKEN=

# =============================================================================
# OPTIONAL — leave empty if not using the feature
# =============================================================================

# Email (SMTP)
SMTP_PASS=

# Email providers (alternative to SMTP)
SENDGRID_API_KEY=
AWS_SES_SECRET_ACCESS_KEY=
RESEND_API_KEY=
MAILGUN_API_KEY=

# SMS providers
TWILIO_AUTH_TOKEN=
AWS_SNS_SECRET_ACCESS_KEY=
VONAGE_API_SECRET=

# OAuth provider secrets
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_SECRET=
GITHUB_CLIENT_SECRET=
OIDC_CLIENT_SECRET=

# LDAP
LDAP_BIND_PASSWORD=

# AI integration
AI_API_KEY=
