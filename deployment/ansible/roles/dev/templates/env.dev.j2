# Auto-generated by Ansible for development — do not commit
# Regenerate with: make dev

# Database
POSTGRES_USER={{ arsenale_db_user }}
POSTGRES_PASSWORD={{ arsenale_db_password }}
POSTGRES_DB={{ arsenale_db_name }}
DATABASE_URL=postgresql://{{ arsenale_db_user }}:{{ arsenale_db_password }}@localhost:5432/{{ arsenale_db_name }}?sslmode=require
DATABASE_URL_DOCKER=postgresql://{{ arsenale_db_user }}:{{ arsenale_db_password }}@postgres:5432/{{ arsenale_db_name }}?sslmode=require

# Server
PORT=3001
GUACAMOLE_WS_PORT=3002
NODE_ENV=development
CLIENT_URL=https://localhost:3000

# TLS (dev certs)
SERVER_TLS_CERT=dev-certs/server/server-cert.pem
SERVER_TLS_KEY=dev-certs/server/server-key.pem
NODE_EXTRA_CA_CERTS=dev-certs/ca.pem
NODE_EXTRA_CA_CERTS_DOCKER=/app/dev-certs/ca.pem

# Guacd
GUACD_HOST=localhost
GUACD_PORT=4822
GUACD_SSL=false

# Cache sidecar (gocache on localhost for dev)
CACHE_SIDECAR_URL=localhost:6380
CACHE_SIDECAR_ENABLED=true

# Secrets (auto-managed by server, or override here)
# JWT_SECRET, GUACAMOLE_SECRET, GUACENC_AUTH_TOKEN are auto-generated on first startup
# SERVER_ENCRYPTION_KEY is required — auto-generated for dev if not set

# Gateway gRPC mTLS (dev certs)
GATEWAY_GRPC_TLS_CA=dev-certs/ca.pem
GATEWAY_GRPC_TLS_CERT=dev-certs/server/server-cert.pem
GATEWAY_GRPC_TLS_KEY=dev-certs/server/server-key.pem

# Tunnel server TLS
TUNNEL_SERVER_CERT=dev-certs/server/server-cert.pem
TUNNEL_SERVER_KEY=dev-certs/server/server-key.pem
TUNNEL_SERVER_CA=dev-certs/ca.pem

# Cache sidecar mTLS (dev certs)
CACHE_SIDECAR_TLS_CA=dev-certs/gocache/ca.pem
CACHE_SIDECAR_TLS_CERT=dev-certs/gocache/client-cert.pem
CACHE_SIDECAR_TLS_KEY=dev-certs/gocache/client-key.pem

# Recording
RECORDING_ENABLED=false
