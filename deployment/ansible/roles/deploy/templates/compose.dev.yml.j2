      - DAC_OVERRIDE
      - FOWNER
      - SETGID
      - SETUID
    security_opt:
      - no-new-privileges:true
    environment:
      POSTGRES_USER: {{ arsenale_db_user }}
      POSTGRES_PASSWORD: {{ arsenale_db_password }}
      POSTGRES_DB: {{ arsenale_db_name }}
    volumes:
      - pgdata_dev:/var/lib/postgresql
      - {{ arsenale_cert_dir }}/postgres/server-cert.pem:/certs/server-cert.pem:ro
      - {{ arsenale_cert_dir }}/postgres/server-key.pem:/certs/server-key.pem:ro
      - {{ arsenale_cert_dir }}/ca.pem:/certs/ca.pem:ro
      - {{ arsenale_home }}/infrastructure/postgres/pg_hba.conf:/etc/postgresql/pg_hba.conf:ro
    command:
      - bash
      - -c
      - |
        cp /certs/server-key.pem /tmp/server.key &&
        chown 999:999 /tmp/server.key &&
        chmod 600 /tmp/server.key &&
        cp /certs/server-cert.pem /tmp/server.crt &&
        cp /certs/ca.pem /tmp/ca.crt &&
        exec docker-entrypoint.sh postgres \
          -c ssl=on \
          -c ssl_cert_file=/tmp/server.crt \
          -c ssl_key_file=/tmp/server.key \
          -c ssl_ca_file=/tmp/ca.crt \
          -c hba_file=/etc/postgresql/pg_hba.conf
    ports:
      - "5432:5432"
    networks:
      - net-dev
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ arsenale_db_user }} -d {{ arsenale_db_name }}"]
      interval: 5s
      timeout: 5s
      retries: 5

  gocache:
    build:
      context: {{ arsenale_home }}/infrastructure/gocache
      dockerfile: Dockerfile
    container_name: gocache
    read_only: true
    tmpfs:
      - /tmp
    environment:
      CACHE_LISTEN: "tcp://0.0.0.0:6380"
      CACHE_HEALTH_ADDR: "0.0.0.0:6381"
      CACHE_DISCOVERY: "manual"
      CACHE_TLS_CA: "${CACHE_TLS_CA:-}"
      CACHE_TLS_CERT: "${CACHE_TLS_CERT:-}"
      CACHE_TLS_KEY: "${CACHE_TLS_KEY:-}"
    volumes:
