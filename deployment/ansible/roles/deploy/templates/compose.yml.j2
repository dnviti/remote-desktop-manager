# =============================================================================
# Arsenale — {{ arsenale_env | default('production') | capitalize }} Podman Compose (Ansible-managed)
# =============================================================================
# Generated by Ansible — do not edit manually.
# Environment: {{ arsenale_env | default('production') }}
# Secrets are managed via Podman secrets (mounted at /run/secrets/).
# =============================================================================
{% set _compose_repo_root = arsenale_source_root | default((_home if (_is_dev | default(false) | bool) else (_home + '/arsenale'))) %}
{% set _compose_project_name = (((_compose_repo_root | realpath | basename) | lower | regex_replace('[^a-z0-9]+', '')) or 'compose') %}
{% set _runtime_assets_root = installer_runtime_assets_dir | default(_home + '/config/installer-assets') %}
{% set _component_images = arsenale_component_images | default({}) %}
{% set _dev_fixture_targets_enabled = arsenale_dev_fixture_targets_enabled | default(_is_dev | default(false) | bool) %}
{% set _dev_demo_databases_enabled = arsenale_dev_demo_databases_enabled | default(_is_dev | default(false) | bool) %}
{% set _dev_tunnel_fixtures_enabled = arsenale_dev_tunnel_fixtures_enabled | default(_is_dev | default(false) | bool) %}
{% macro local_image(service_name) -%}
localhost/{{ _compose_project_name }}_{{ service_name }}:latest
{%- endmacro %}
{% macro remote_image(service_name, fallback_name='') -%}
{{ _component_images.get(service_name, arsenale_registry ~ '/' ~ (fallback_name if fallback_name else service_name) ~ ':' ~ arsenale_image_tag) }}
{%- endmacro %}
{% macro compose_service_source(service_name, dockerfile, image_service_name='', context='', build_args=None) -%}
{% set _context = context if context else _compose_repo_root %}
{% if _build | bool %}
build:
  context: {{ _context }}
  dockerfile: {{ dockerfile }}
{% if build_args %}
  args:
{% for key, value in build_args.items() %}
    {{ key }}: {{ value }}
{% endfor %}
{% endif %}
{% elif _is_dev | default(false) | bool %}
image: {{ local_image(service_name) }}
{% else %}
image: {{ remote_image(service_name, image_service_name) }}
pull_policy: always
{% endif %}
{%- endmacro %}

services:

  # ---------------------------------------------------------------------------
  # PostgreSQL — Primary database
  # ---------------------------------------------------------------------------
  postgres:
    image: {{ arsenale_postgres_image }}
    container_name: arsenale-postgres
    user: "0:0"
    read_only: true
    cpus: "{{ arsenale_resource_limits.postgres.cpus }}"
    mem_limit: "{{ arsenale_resource_limits.postgres.memory }}"
    pids_limit: {{ arsenale_resource_limits.postgres.pids }}
    tmpfs:
      - /tmp
      - /var/lib/pgsql
      - /run/postgresql
    environment:
      POSTGRES_USER: "{{ arsenale_db_user }}"
      POSTGRES_DB: "{{ arsenale_db_name }}"
      POSTGRES_PASSWORD_FILE: /run/secrets/postgres_password
    secrets:
      - postgres_password
    volumes:
      - pgdata:{{ arsenale_postgres_data_dir | default('/var/lib/pgsql/data') }}
      - {{ _runtime_assets_root }}/postgres/pg_hba.conf:/etc/postgresql/pg_hba.conf:ro
      - {{ arsenale_cert_dir }}/postgres:/certs:ro
      - {{ _runtime_assets_root }}/postgres/entrypoint.sh:/usr/local/bin/arsenale-postgres-entrypoint.sh:ro
    entrypoint: ["/usr/local/bin/arsenale-postgres-entrypoint.sh"]
    restart: always
    cap_drop:
      - ALL
    cap_add:
      - CHOWN
      - DAC_OVERRIDE
      - FOWNER
      - SETGID
      - SETUID
    security_opt:
      - no-new-privileges:true
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ arsenale_db_user }} -d {{ arsenale_db_name }}"]
      interval: 5s
      timeout: 5s
      retries: 5
    networks:
      - net-db

  migrate:
{{ compose_service_source('migrate', 'backend/Dockerfile', 'control-plane-api', build_args={'SERVICE': 'control-plane-api'}) | indent(4, true) }}
    container_name: arsenale-migrate
    entrypoint: ["/usr/local/bin/migrate"]
    command: ["up"]
    read_only: true
    cpus: "0.25"
    mem_limit: "256m"
    pids_limit: 64
    tmpfs:
      - /tmp
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    secrets:
      - database_url
    environment:
      DATABASE_URL_FILE: /run/secrets/database_url
      DATABASE_SSL_ROOT_CERT: /certs/postgres/ca.pem
      ARSENALE_SKIP_MIGRATION_CHECK: "true"
    depends_on:
      postgres:
        condition: service_healthy
    volumes:
      - {{ arsenale_cert_dir }}/postgres:/certs/postgres:ro
    restart: "no"
    networks:
      - net-db

  # ---------------------------------------------------------------------------
  # Apache Guacamole Daemon (guacd) — RDP/VNC protocol handler
  # ---------------------------------------------------------------------------
  guacd:
{{ compose_service_source('guacd', 'gateways/guacd/Dockerfile') | indent(4, true) }}
    container_name: arsenale-guacd
    read_only: true
    cpus: "{{ arsenale_resource_limits.guacd.cpus }}"
    mem_limit: "{{ arsenale_resource_limits.guacd.memory }}"
    pids_limit: {{ arsenale_resource_limits.guacd.pids }}
    tmpfs:
      - /tmp
    environment:
      GUACD_SSL: "true"
      GUACD_SSL_CERT: /certs/server-cert.pem
      GUACD_SSL_KEY: /certs/server-key.pem
    volumes:
      - arsenale_drive:/guacd-drive
      - arsenale_recordings:/recordings
      - {{ arsenale_cert_dir }}/guacd:/certs:ro
    restart: always
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    healthcheck:
      test: ["CMD-SHELL", "netstat -tln | grep -q ':4822 ' || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 10s
    networks:
      - net-egress
      - net-guacd

  # ---------------------------------------------------------------------------
  # Guacenc — Session recording video converter
  # ---------------------------------------------------------------------------
  guacenc:
{{ compose_service_source('guacenc', 'Dockerfile', context=_compose_repo_root ~ '/gateways/guacenc') | indent(4, true) }}
    container_name: arsenale-guacenc
    read_only: true
    cpus: "{{ arsenale_resource_limits.guacenc.cpus }}"
    mem_limit: "{{ arsenale_resource_limits.guacenc.memory }}"
    pids_limit: {{ arsenale_resource_limits.guacenc.pids }}
    tmpfs:
      - /tmp
    environment:
      GUACENC_AUTH_TOKEN_FILE: /run/secrets/guacenc_auth_token
      REDIS_URL: "redis://redis:6379/0"
      GUACENC_TLS_CERT: /certs/guacenc/server-cert.pem
      GUACENC_TLS_KEY: /certs/guacenc/server-key.pem
    secrets:
      - guacenc_auth_token
    volumes:
      - arsenale_recordings:/recordings
      - {{ arsenale_cert_dir }}:/certs:ro
    restart: always
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    healthcheck:
      test: ["CMD-SHELL", "curl --silent --show-error --fail --insecure https://127.0.0.1:3003/health >/dev/null || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 5s
    networks:
      - net-guacenc
      - net-cache

  # ---------------------------------------------------------------------------
  # Redis — preferred distributed coordination backend
  # ---------------------------------------------------------------------------
  redis:
    image: quay.io/sclorg/redis-7-c9s
    container_name: arsenale-redis
    command:
      - run-redis
      - --appendonly
      - "yes"
    cpus: "0.5"
    mem_limit: "256m"
    pids_limit: 256
    tmpfs:
      - /tmp
    restart: always
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    volumes:
      - arsenale_redis:/var/lib/redis/data
    healthcheck:
      test: ["CMD-SHELL", "redis-cli -h 127.0.0.1 -p 6379 ping | grep -q PONG"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 5s
    networks:
      - net-cache

{% if not (_is_dev | default(false) | bool) %}
  # ---------------------------------------------------------------------------
  # Go backend foundation services required in production
  # ---------------------------------------------------------------------------
  control-plane-api:
{{ compose_service_source('control-plane-api', 'backend/Dockerfile', build_args={'SERVICE': 'control-plane-api'}) | indent(4, true) }}
    container_name: arsenale-control-plane-api
    entrypoint:
      - /bin/sh
      - -lc
      - mkdir -p /guacd-drive /recordings && { chmod 1777 /guacd-drive /recordings || true; } && exec /usr/local/bin/service
    user: "0:0"
    read_only: true
    cpus: "{{ arsenale_resource_limits.go_service.cpus }}"
    mem_limit: "{{ arsenale_resource_limits.go_service.memory }}"
    pids_limit: {{ arsenale_resource_limits.go_service.pids }}
    tmpfs:
      - /tmp
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    secrets:
      - database_url
      - guacamole_secret
      - guacenc_auth_token
      - jwt_secret
      - shared_files_s3_secret_access_key
      - server_encryption_key
    environment:
      PORT: "8080"
      ARSENALE_VERSION: "{{ arsenale_image_tag }}"
      GO_QUERY_RUNNER_ENABLED: "true"
      HIBP_FAIL_OPEN: "true"
      DRIVE_BASE_PATH: "/guacd-drive"
      FILE_UPLOAD_MAX_SIZE: "104857600"
      USER_DRIVE_QUOTA: "104857600"
      FILE_THREAT_SCANNER_MODE: "${FILE_THREAT_SCANNER_MODE:-builtin}"
      SHARED_FILES_S3_BUCKET: "${SHARED_FILES_S3_BUCKET:-}"
      SHARED_FILES_S3_REGION: "${SHARED_FILES_S3_REGION:-us-east-1}"
      SHARED_FILES_S3_ENDPOINT: "${SHARED_FILES_S3_ENDPOINT:-}"
      SHARED_FILES_S3_ACCESS_KEY_ID: "${SHARED_FILES_S3_ACCESS_KEY_ID:-}"
      SHARED_FILES_S3_SECRET_ACCESS_KEY: "${SHARED_FILES_S3_SECRET_ACCESS_KEY:-}"
      SHARED_FILES_S3_SECRET_ACCESS_KEY_FILE: /run/secrets/shared_files_s3_secret_access_key
      SHARED_FILES_S3_PREFIX: "${SHARED_FILES_S3_PREFIX:-}"
      SHARED_FILES_S3_FORCE_PATH_STYLE: "${SHARED_FILES_S3_FORCE_PATH_STYLE:-false}"
      SHARED_FILES_S3_AUTO_CREATE_BUCKET: "${SHARED_FILES_S3_AUTO_CREATE_BUCKET:-false}"
      DATABASE_URL_FILE: /run/secrets/database_url
      DATABASE_SSL_ROOT_CERT: /certs/postgres/ca.pem
      REDIS_URL: "redis://redis:6379/0"
      ARSENALE_INSTALLER_ENABLED: "${ARSENALE_INSTALLER_ENABLED:-false}"
      ARSENALE_INSTALL_MODE: "${ARSENALE_INSTALL_MODE:-production}"
      ARSENALE_INSTALL_BACKEND: "${ARSENALE_INSTALL_BACKEND:-podman}"
      ARSENALE_INSTALL_CAPABILITIES: "${ARSENALE_INSTALL_CAPABILITIES:-core,keychain,multi_tenancy,connections,ip_geolocation,databases,recordings,zero_trust,agentic_ai,enterprise_auth,sharing_approvals,cli}"
      ARSENALE_DIRECT_ROUTING_ENABLED: "${ARSENALE_DIRECT_ROUTING_ENABLED:-true}"
      ARSENALE_ZERO_TRUST_ENABLED: "${ARSENALE_ZERO_TRUST_ENABLED:-true}"
      FEATURE_CONNECTIONS_ENABLED: "${FEATURE_CONNECTIONS_ENABLED:-true}"
      FEATURE_IP_GEOLOCATION_ENABLED: "${FEATURE_IP_GEOLOCATION_ENABLED:-true}"
      FEATURE_DATABASE_PROXY_ENABLED: "${FEATURE_DATABASE_PROXY_ENABLED:-true}"
      FEATURE_KEYCHAIN_ENABLED: "${FEATURE_KEYCHAIN_ENABLED:-true}"
      FEATURE_MULTI_TENANCY_ENABLED: "${FEATURE_MULTI_TENANCY_ENABLED:-true}"
      FEATURE_RECORDINGS_ENABLED: "${FEATURE_RECORDINGS_ENABLED:-true}"
      FEATURE_ZERO_TRUST_ENABLED: "${FEATURE_ZERO_TRUST_ENABLED:-true}"
      FEATURE_AGENTIC_AI_ENABLED: "${FEATURE_AGENTIC_AI_ENABLED:-true}"
      FEATURE_ENTERPRISE_AUTH_ENABLED: "${FEATURE_ENTERPRISE_AUTH_ENABLED:-true}"
      FEATURE_SHARING_APPROVALS_ENABLED: "${FEATURE_SHARING_APPROVALS_ENABLED:-true}"
      GATEWAY_ROUTING_MODE: "${GATEWAY_ROUTING_MODE:-gateway-mandatory}"
      ALLOW_EXTERNAL_SHARING: "${ALLOW_EXTERNAL_SHARING:-false}"
      CLI_ENABLED: "${CLI_ENABLED:-true}"
      RECORDING_ENABLED: "${FEATURE_RECORDINGS_ENABLED:-true}"
      RECORDING_PATH: "/recordings"
      GUACAMOLE_SECRET_FILE: /run/secrets/guacamole_secret
      GUACENC_AUTH_TOKEN_FILE: /run/secrets/guacenc_auth_token
      GUACENC_SERVICE_URL: "https://guacenc:3003"
      GUACENC_USE_TLS: "true"
      GUACENC_TLS_CA: /certs/guacenc/ca.pem
      GUACENC_TIMEOUT_MS: "120000"
      GUACENC_RECORDING_PATH: "/recordings"
      ASCIICAST_CONVERTER_URL: "https://guacenc:3003"
      JWT_SECRET_FILE: /run/secrets/jwt_secret
      SERVER_ENCRYPTION_KEY_FILE: /run/secrets/server_encryption_key
    ports:
      - "{{ arsenale_service_bind_host | default('0.0.0.0') }}:{{ arsenale_control_plane_api_port | default(18080) }}:8080"
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
    volumes:
      - arsenale_drive:/guacd-drive
      - arsenale_recordings:/recordings
      - {{ arsenale_cert_dir }}/postgres:/certs/postgres:ro
      - {{ arsenale_cert_dir }}/guacenc:/certs/guacenc:ro
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://127.0.0.1:8080/healthz >/dev/null || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 5s
    restart: always
    networks:
      - net-egress
      - net-edge
      - net-db
      - net-cache
      - net-guacd
      - net-gateway

  tunnel-broker:
{{ compose_service_source('tunnel-broker', 'backend/Dockerfile', build_args={'SERVICE': 'tunnel-broker'}) | indent(4, true) }}
    container_name: arsenale-tunnel-broker
    read_only: true
    cpus: "0.5"
    mem_limit: "256m"
    pids_limit: 128
    tmpfs:
      - /tmp
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    secrets:
      - database_url
      - server_encryption_key
    environment:
      PORT: "8092"
      ARSENALE_VERSION: "{{ arsenale_image_tag }}"
      DATABASE_URL_FILE: /run/secrets/database_url
      DATABASE_SSL_ROOT_CERT: /certs/postgres/ca.pem
      SERVER_ENCRYPTION_KEY_FILE: /run/secrets/server_encryption_key
      SPIFFE_TRUST_DOMAIN: "{{ arsenale_spiffe_trust_domain | default('arsenale.local') }}"
      TUNNEL_TCP_PROXY_BIND_HOST: "0.0.0.0"
      TUNNEL_TCP_PROXY_ADVERTISE_HOST: "tunnel-broker"
    ports:
      - "{{ arsenale_service_bind_host | default('0.0.0.0') }}:{{ arsenale_tunnel_broker_port | default(18092) }}:8092"
    depends_on:
      postgres:
        condition: service_healthy
    volumes:
      - {{ arsenale_cert_dir }}/postgres:/certs/postgres:ro
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://127.0.0.1:8092/healthz >/dev/null || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 5s
    restart: always
    networks:
      - net-edge
      - net-egress
      - net-db
      - net-gateway

  query-runner:
{{ compose_service_source('query-runner', 'backend/Dockerfile', build_args={'SERVICE': 'query-runner'}) | indent(4, true) }}
    container_name: arsenale-query-runner
    read_only: true
    cpus: "{{ arsenale_resource_limits.go_service.cpus }}"
    mem_limit: "{{ arsenale_resource_limits.go_service.memory }}"
    pids_limit: {{ arsenale_resource_limits.go_service.pids }}
    tmpfs:
      - /tmp
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    secrets:
      - database_url
    environment:
      PORT: "8093"
      ARSENALE_VERSION: "{{ arsenale_image_tag }}"
      DATABASE_URL_FILE: /run/secrets/database_url
      DATABASE_SSL_ROOT_CERT: /certs/postgres/ca.pem
    ports:
      - "{{ arsenale_service_bind_host | default('0.0.0.0') }}:{{ arsenale_query_runner_port | default(18093) }}:8093"
    depends_on:
      postgres:
        condition: service_healthy
    volumes:
      - {{ arsenale_cert_dir }}/postgres:/certs/postgres:ro
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://127.0.0.1:8093/healthz >/dev/null || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 5s
    restart: always
    networks:
      - net-egress
      - net-edge
      - net-db

  desktop-broker:
{{ compose_service_source('desktop-broker', 'backend/Dockerfile', build_args={'SERVICE': 'desktop-broker'}) | indent(4, true) }}
    container_name: arsenale-desktop-broker
    read_only: true
    cpus: "{{ arsenale_resource_limits.go_service.cpus }}"
    mem_limit: "{{ arsenale_resource_limits.go_service.memory }}"
    pids_limit: {{ arsenale_resource_limits.go_service.pids }}
    tmpfs:
      - /tmp
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    secrets:
      - database_url
      - guacamole_secret
    environment:
      PORT: "8091"
      ARSENALE_VERSION: "{{ arsenale_image_tag }}"
      DATABASE_URL_FILE: /run/secrets/database_url
      DATABASE_SSL_ROOT_CERT: /certs/postgres/ca.pem
      GUACAMOLE_SECRET_FILE: /run/secrets/guacamole_secret
      GUACD_HOST: guacd
      GUACD_PORT: "4822"
      GUACD_SSL: "true"
      GUACD_CA_CERT: /certs/ca/ca.pem
    ports:
      - "{{ arsenale_service_bind_host | default('0.0.0.0') }}:{{ arsenale_desktop_broker_port | default(18091) }}:8091"
    depends_on:
      postgres:
        condition: service_healthy
      guacd:
        condition: service_healthy
    volumes:
      - arsenale_recordings:/recordings
      - {{ arsenale_cert_dir }}/postgres:/certs/postgres:ro
      - {{ arsenale_cert_dir }}:/certs/ca:ro
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://127.0.0.1:8091/healthz >/dev/null || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 5s
    restart: always
    networks:
      - net-edge
      - net-guacd
      - net-db

  terminal-broker:
{{ compose_service_source('terminal-broker', 'backend/Dockerfile', build_args={'SERVICE': 'terminal-broker'}) | indent(4, true) }}
    container_name: arsenale-terminal-broker
    read_only: true
    cpus: "{{ arsenale_resource_limits.go_service.cpus }}"
    mem_limit: "{{ arsenale_resource_limits.go_service.memory }}"
    pids_limit: {{ arsenale_resource_limits.go_service.pids }}
    tmpfs:
      - /tmp
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    secrets:
      - database_url
      - guacamole_secret
    environment:
      PORT: "8090"
      ARSENALE_VERSION: "{{ arsenale_image_tag }}"
      DATABASE_URL_FILE: /run/secrets/database_url
      DATABASE_SSL_ROOT_CERT: /certs/postgres/ca.pem
      GUACAMOLE_SECRET_FILE: /run/secrets/guacamole_secret
    ports:
      - "{{ arsenale_service_bind_host | default('0.0.0.0') }}:{{ arsenale_terminal_broker_port | default(18090) }}:8090"
    depends_on:
      postgres:
        condition: service_healthy
    volumes:
      - arsenale_recordings:/recordings
      - {{ arsenale_cert_dir }}/postgres:/certs/postgres:ro
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://127.0.0.1:8090/healthz >/dev/null || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 5s
    restart: always
    networks:
      - net-edge
      - net-db
{% endif %}

{% if _is_dev | default(false) | bool %}
  shared-files-s3:
    image: {{ arsenale_dev_shared_files_s3_image | default('quay.io/minio/minio:latest') }}
    container_name: arsenale-shared-files-s3
    command: ["server", "/data", "--console-address", ":9001"]
    environment:
      MINIO_ROOT_USER: "${SHARED_FILES_S3_ACCESS_KEY_ID:-arsenale}"
      MINIO_ROOT_PASSWORD: "${SHARED_FILES_S3_SECRET_ACCESS_KEY:-arsenale-dev-shared-files}"
      MINIO_REGION_NAME: "${SHARED_FILES_S3_REGION:-us-east-1}"
    volumes:
      - shared_files_s3_data:/data
    healthcheck:
      test: ["CMD-SHELL", "curl --silent --fail http://127.0.0.1:9000/minio/health/live >/dev/null || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 5s
    restart: always
    networks:
      - net-cache

  # ---------------------------------------------------------------------------
  # Go backend foundation services — active public runtime
  # ---------------------------------------------------------------------------
  control-plane-api:
{{ compose_service_source('control-plane-api', 'backend/Dockerfile', build_args={'SERVICE': 'control-plane-api'}) | indent(4, true) }}
    container_name: arsenale-control-plane-api
    entrypoint:
      - /bin/sh
      - -lc
      - mkdir -p /guacd-drive /recordings && { chmod 1777 /guacd-drive /recordings || true; } && exec /usr/local/bin/service
    user: "0:0"
    read_only: true
    cpus: "{{ arsenale_resource_limits.go_service.cpus }}"
    mem_limit: "{{ arsenale_resource_limits.go_service.memory }}"
    pids_limit: {{ arsenale_resource_limits.go_service.pids }}
    tmpfs:
      - /tmp
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    secrets:
      - database_url
      - guacamole_secret
      - guacenc_auth_token
      - jwt_secret
      - shared_files_s3_secret_access_key
      - server_encryption_key
    environment:
      PORT: "8080"
      ARSENALE_VERSION: "{{ arsenale_image_tag }}"
      GO_QUERY_RUNNER_ENABLED: "true"
      HIBP_FAIL_OPEN: "true"
      CLIENT_URL: "{{ _public_url }}"
      WEBAUTHN_RP_ID: "{{ arsenale_domain }}"
      WEBAUTHN_RP_ORIGIN: "{{ _public_url }}"
      ORCHESTRATOR_TYPE: "podman"
      PODMAN_SOCKET_PATH: "/run/podman/podman.sock"
      ORCHESTRATOR_EGRESS_NETWORK: "arsenale-net-egress"
      ORCHESTRATOR_EDGE_NETWORK: "arsenale-net-edge"
      ORCHESTRATOR_DB_NETWORK: "arsenale-net-db"
      ORCHESTRATOR_GUACD_NETWORK: "arsenale-net-guacd"
      ORCHESTRATOR_GATEWAY_NETWORK: "arsenale-net-gateway"
      ORCHESTRATOR_SSH_GATEWAY_IMAGE: "{{ local_image('ssh-gateway') }}"
      ORCHESTRATOR_GUACD_IMAGE: "{{ local_image('guacd') }}"
