# =============================================================================
# Arsenale — {{ arsenale_env | default('production') | capitalize }} Podman Compose (Ansible-managed)
# =============================================================================
# Generated by Ansible — do not edit manually.
# Environment: {{ arsenale_env | default('production') }}
# Secrets are managed via Podman secrets (mounted at /run/secrets/).
# =============================================================================

services:

  # ---------------------------------------------------------------------------
  # PostgreSQL — Primary database
  # ---------------------------------------------------------------------------
  postgres:
    image: postgres:16
    container_name: arsenale-postgres
    read_only: true
    cpus: "{{ arsenale_resource_limits.postgres.cpus }}"
    mem_limit: "{{ arsenale_resource_limits.postgres.memory }}"
    pids_limit: {{ arsenale_resource_limits.postgres.pids }}
    tmpfs:
      - /tmp
      - /run/postgresql
    environment:
      POSTGRES_USER: "{{ arsenale_db_user }}"
      POSTGRES_DB: "{{ arsenale_db_name }}"
      POSTGRES_PASSWORD_FILE: /run/secrets/postgres_password
    secrets:
      - postgres_password
    volumes:
      - pgdata:/var/lib/postgresql/data
      - {{ _home }}{% if not (_is_dev | default(false) | bool) %}/arsenale{% endif %}/infrastructure/postgres/pg_hba.conf:/etc/postgresql/pg_hba.conf:ro
      - {{ arsenale_cert_dir }}/postgres:/certs:ro
      - {{ _home }}{% if not (_is_dev | default(false) | bool) %}/arsenale{% endif %}/infrastructure/postgres/entrypoint.sh:/usr/local/bin/arsenale-postgres-entrypoint.sh:ro
    entrypoint: ["/usr/local/bin/arsenale-postgres-entrypoint.sh"]
    restart: always
    cap_drop:
      - ALL
    cap_add:
      - CHOWN
      - DAC_OVERRIDE
      - FOWNER
      - SETGID
      - SETUID
    security_opt:
      - no-new-privileges:true
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ arsenale_db_user }} -d {{ arsenale_db_name }}"]
      interval: 5s
      timeout: 5s
      retries: 5
    networks:
      - net-db

  # ---------------------------------------------------------------------------
  # Apache Guacamole Daemon (guacd) — RDP/VNC protocol handler
  # ---------------------------------------------------------------------------
  guacd:
    image: {{ arsenale_guacd_image }}
    container_name: arsenale-guacd
    read_only: true
    cpus: "{{ arsenale_resource_limits.guacd.cpus }}"
    mem_limit: "{{ arsenale_resource_limits.guacd.memory }}"
    pids_limit: {{ arsenale_resource_limits.guacd.pids }}
    tmpfs:
      - /tmp
    environment:
      GUACD_SSL: "true"
      GUACD_SSL_CERT: /certs/server-cert.pem
      GUACD_SSL_KEY: /certs/server-key.pem
    volumes:
      - arsenale_drive:/guacd-drive
      - arsenale_recordings:/recordings
      - {{ arsenale_cert_dir }}/guacd:/certs:ro
    restart: always
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    healthcheck:
      test: ["CMD-SHELL", "netstat -tln | grep -q ':4822 ' || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 10s
    networks:
      - net-guacd

  # ---------------------------------------------------------------------------
  # Guacenc — Session recording video converter
  # ---------------------------------------------------------------------------
  guacenc:
{% if _build | bool %}
    build:
      context: {{ _home }}{% if not (_is_dev | default(false) | bool) %}/arsenale{% endif %}/gateways/guacenc
      dockerfile: Dockerfile
{% else %}
    image: {{ arsenale_registry }}/guacenc:{{ arsenale_image_tag }}
{% endif %}
    container_name: arsenale-guacenc
    read_only: true
    cpus: "{{ arsenale_resource_limits.guacenc.cpus }}"
    mem_limit: "{{ arsenale_resource_limits.guacenc.memory }}"
    pids_limit: {{ arsenale_resource_limits.guacenc.pids }}
    tmpfs:
      - /tmp
    environment:
      GUACENC_AUTH_TOKEN_FILE: /run/secrets/guacenc_auth_token
      CACHE_PUBSUB_URL: "gocache-pubsub:6380"
      CACHE_PUBSUB_TLS_CA: /certs/gocache-pubsub/ca.pem
      CACHE_PUBSUB_TLS_CERT: /certs/gocache-pubsub/client-cert.pem
      CACHE_PUBSUB_TLS_KEY: /certs/gocache-pubsub/client-key.pem
      GUACENC_TLS_CERT: /certs/guacenc/server-cert.pem
      GUACENC_TLS_KEY: /certs/guacenc/server-key.pem
    secrets:
      - guacenc_auth_token
    volumes:
      - arsenale_recordings:/recordings
      - {{ arsenale_cert_dir }}:/certs:ro
    depends_on:
      gocache-pubsub:
        condition: service_healthy
    restart: always
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    healthcheck:
      test: ["CMD-SHELL", "curl --silent --show-error --fail --cacert /certs/ca.pem https://localhost:3003/health >/dev/null || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 5s
    networks:
      - net-guacenc
      - net-cache

  # ---------------------------------------------------------------------------
  # GoCache Cache — KV / TTL / locks / queues
  # ---------------------------------------------------------------------------
  gocache-cache:
{% if _build | bool %}
    build:
      context: {{ _home }}{% if not (_is_dev | default(false) | bool) %}/arsenale{% endif %}/infrastructure/gocache
      dockerfile: Dockerfile
{% else %}
    image: {{ arsenale_registry }}/gocache:{{ arsenale_image_tag }}
{% endif %}
{% if arsenale_gocache_cache_replicas | default(1) | int <= 1 %}
    container_name: arsenale-gocache-cache
{% endif %}
{% if arsenale_gocache_cache_replicas | default(1) | int > 1 %}
    deploy:
      replicas: {{ arsenale_gocache_cache_replicas }}
{% endif %}
    read_only: true
    cpus: "{{ arsenale_resource_limits.gocache_cache.cpus }}"
    mem_limit: "{{ arsenale_resource_limits.gocache_cache.memory }}"
    pids_limit: {{ arsenale_resource_limits.gocache_cache.pids }}
    tmpfs:
      - /tmp
    environment:
      CACHE_ROLE: "cache"
      SPIFFE_TRUST_DOMAIN: "{{ arsenale_spiffe_trust_domain | default('arsenale.local') }}"
      CACHE_LISTEN: "tcp://0.0.0.0:6380"
      CACHE_HEALTH_ADDR: "0.0.0.0:6381"
      CACHE_DISCOVERY: "{{ arsenale_gocache_cache_peer_discovery | default('dns') }}"
      CACHE_DNS_NAME: "gocache-cache"
      CACHE_PEER_SPIFFE_ID: "spiffe://{{ arsenale_spiffe_trust_domain | default('arsenale.local') }}/service/gocache-cache"
      CACHE_CLIENT_SPIFFE_ID: "spiffe://{{ arsenale_spiffe_trust_domain | default('arsenale.local') }}/service/server"
{% if arsenale_gocache_cache_peers %}
      CACHE_PEERS: "{{ arsenale_gocache_cache_peers }}"
{% endif %}
      CACHE_TLS_CA: /certs/ca.pem
      CACHE_TLS_CERT: /certs/server-cert.pem
      CACHE_TLS_KEY: /certs/server-key.pem
    volumes:
      - gocache_cache_data:/data
      - {{ arsenale_cert_dir }}/gocache-cache:/certs:ro
    restart: always
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    healthcheck:
      test: ["CMD-SHELL", "curl --silent --show-error --fail --cacert /certs/ca.pem https://localhost:6381/health >/dev/null || exit 1"]
      interval: 10s
      timeout: 3s
      retries: 3
      start_period: 5s
    networks:
      - net-cache

  # ---------------------------------------------------------------------------
  # GoCache PubSub — central service-to-service data wiring
  # ---------------------------------------------------------------------------
  gocache-pubsub:
{% if _build | bool %}
    build:
      context: {{ _home }}{% if not (_is_dev | default(false) | bool) %}/arsenale{% endif %}/infrastructure/gocache
      dockerfile: Dockerfile
{% else %}
    image: {{ arsenale_registry }}/gocache:{{ arsenale_image_tag }}
{% endif %}
{% if arsenale_gocache_pubsub_replicas | default(1) | int <= 1 %}
    container_name: arsenale-gocache-pubsub
{% endif %}
{% if arsenale_gocache_pubsub_replicas | default(1) | int > 1 %}
    deploy:
      replicas: {{ arsenale_gocache_pubsub_replicas }}
{% endif %}
    read_only: true
    cpus: "{{ arsenale_resource_limits.gocache_pubsub.cpus }}"
    mem_limit: "{{ arsenale_resource_limits.gocache_pubsub.memory }}"
    pids_limit: {{ arsenale_resource_limits.gocache_pubsub.pids }}
    tmpfs:
      - /tmp
    environment:
      CACHE_ROLE: "pubsub"
      SPIFFE_TRUST_DOMAIN: "{{ arsenale_spiffe_trust_domain | default('arsenale.local') }}"
      CACHE_LISTEN: "tcp://0.0.0.0:6380"
      CACHE_HEALTH_ADDR: "0.0.0.0:6381"
      CACHE_DISCOVERY: "{{ arsenale_gocache_pubsub_peer_discovery | default('dns') }}"
      CACHE_DNS_NAME: "gocache-pubsub"
      CACHE_PEER_SPIFFE_ID: "spiffe://{{ arsenale_spiffe_trust_domain | default('arsenale.local') }}/service/gocache-pubsub"
      CACHE_CLIENT_SPIFFE_ID: "spiffe://{{ arsenale_spiffe_trust_domain | default('arsenale.local') }}/service/server"
{% if arsenale_gocache_pubsub_peers %}
      CACHE_PEERS: "{{ arsenale_gocache_pubsub_peers }}"
{% endif %}
      CACHE_TLS_CA: /certs/ca.pem
      CACHE_TLS_CERT: /certs/server-cert.pem
      CACHE_TLS_KEY: /certs/server-key.pem
    restart: always
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    healthcheck:
      test: ["CMD-SHELL", "curl --silent --show-error --fail --cacert /certs/ca.pem https://localhost:6381/health >/dev/null || exit 1"]
      interval: 10s
      timeout: 3s
      retries: 3
      start_period: 5s
    volumes:
      - {{ arsenale_cert_dir }}/gocache-pubsub:/certs:ro
    networks:
      - net-cache

  # ---------------------------------------------------------------------------
  # Server — Express.js API + WebSocket backend
  # ---------------------------------------------------------------------------
  server:
{% if _build | bool %}
    build:
      context: {{ _home }}{% if not (_is_dev | default(false) | bool) %}/arsenale{% endif %}

      dockerfile: server/Dockerfile
{% else %}
    image: {{ arsenale_registry }}/server:{{ arsenale_image_tag }}
{% endif %}
{% if arsenale_server_replicas | default(1) | int <= 1 %}
    container_name: arsenale-server
{% endif %}
{% if arsenale_server_replicas | default(1) | int > 1 %}
    deploy:
      replicas: {{ arsenale_server_replicas }}
{% endif %}
    read_only: true
    cpus: "{{ arsenale_resource_limits.server.cpus }}"
    mem_limit: "{{ arsenale_resource_limits.server.memory }}"
    pids_limit: {{ arsenale_resource_limits.server.pids }}
    tmpfs:
      - /tmp
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    secrets:
      - jwt_secret
      - guacamole_secret
      - server_encryption_key
      - database_url
      - guacenc_auth_token
      - smtp_pass
      - sendgrid_api_key
      - ses_secret_access_key
      - resend_api_key
      - mailgun_api_key
      - twilio_auth_token
      - sns_secret_access_key
      - vonage_api_secret
      - google_client_secret
      - microsoft_client_secret
      - github_client_secret
      - oidc_client_secret
      - ldap_bind_password
      - ai_api_key
    environment:
      NODE_ENV: "{{ arsenale_node_env }}"
      SPIFFE_TRUST_DOMAIN: "{{ arsenale_spiffe_trust_domain | default('arsenale.local') }}"
      NODE_EXTRA_CA_CERTS: /certs/ca.pem
      CLI_ENABLED: "{{ 'true' if (_is_dev | default(false) | bool) else 'false' }}"
      DEV_TUNNEL_CERT_DIR: "{{ '/certs' if (_is_dev | default(false) | bool) else '' }}"
      LOG_LEVEL: "{{ arsenale_log_level | default('info') }}"
      LOG_HTTP_REQUESTS: "{{ arsenale_log_http_requests | default('false') }}"
      LOG_GUACAMOLE: "{{ arsenale_log_guacamole | default('false') }}"
      PORT: "3001"
      GUACAMOLE_WS_PORT: "3002"
      DATABASE_URL: ""
      CLIENT_URL: "https://{{ arsenale_domain }}:{{ arsenale_client_port }}"
      TRUST_PROXY: "{{ arsenale_trust_proxy_effective | string | lower }}"
      COOKIE_SECURE: "{{ _cookie_secure | string | lower }}"
      GUACD_HOST: guacd
      GUACD_PORT: "4822"
      GUACD_SSL: "true"
      GUACD_CA_CERT: /certs/ca.pem
      GUACENC_SERVICE_URL: "https://guacenc:3003"
      GUACENC_USE_TLS: "true"
      GUACENC_TLS_CA: /certs/guacenc/ca.pem
      CACHE_SIDECAR_ENABLED: "true"
      CACHE_KV_URL: "gocache-cache:6380"
      CACHE_KV_TLS_CA: /certs/gocache-cache/ca.pem
      CACHE_KV_TLS_CERT: /certs/gocache-cache/client-cert.pem
      CACHE_KV_TLS_KEY: /certs/gocache-cache/client-key.pem
      CACHE_PUBSUB_URL: "gocache-pubsub:6380"
      CACHE_PUBSUB_TLS_CA: /certs/gocache-pubsub/ca.pem
      CACHE_PUBSUB_TLS_CERT: /certs/gocache-pubsub/client-cert.pem
      CACHE_PUBSUB_TLS_KEY: /certs/gocache-pubsub/client-key.pem
      SERVER_TLS_CERT: /certs/server/server-cert.pem
      SERVER_TLS_KEY: /certs/server/server-key.pem
      TUNNEL_SERVER_CERT: /certs/server/server-cert.pem
      TUNNEL_SERVER_KEY: /certs/server/server-key.pem
      TUNNEL_SERVER_CA: /certs/ca.pem
      TUNNEL_STRICT_MTLS: "{{ 'true' if (_is_dev | default(false) | bool) else 'false' }}"
      RECORDING_ENABLED: "{{ arsenale_recording_enabled | string | lower }}"
      RECORDING_PATH: /recordings
      ALLOW_LOCAL_NETWORK: "{{ arsenale_allow_local_network | string | lower }}"
      SELF_SIGNUP_ENABLED: "{{ arsenale_self_signup_enabled | string | lower }}"
      EMAIL_PROVIDER: "{{ arsenale_email_provider }}"
      GATEWAY_GRPC_TLS_CA: /certs/ca.pem
      GATEWAY_GRPC_TLS_CERT: /certs/ssh-gateway/client-cert.pem
      GATEWAY_GRPC_TLS_KEY: /certs/ssh-gateway/client-key.pem
    volumes:
      - arsenale_drive:/guacd-drive
      - arsenale_recordings:/recordings
      - {{ arsenale_cert_dir }}/ca.pem:/certs/ca.pem:ro
{% if _is_dev | default(false) | bool %}
      - {{ arsenale_cert_dir }}/ca-key.pem:/certs/ca-key.pem:ro
      - {{ arsenale_cert_dir }}/tunnel-managed-ssh:/certs/tunnel-managed-ssh:ro
      - {{ arsenale_cert_dir }}/tunnel-guacd:/certs/tunnel-guacd:ro
      - {{ arsenale_cert_dir }}/tunnel-db-proxy:/certs/tunnel-db-proxy:ro
{% endif %}
      - {{ arsenale_cert_dir }}/server:/certs/server:ro
      - {{ arsenale_cert_dir }}/gocache-cache:/certs/gocache-cache:ro
      - {{ arsenale_cert_dir }}/gocache-pubsub:/certs/gocache-pubsub:ro
      - {{ arsenale_cert_dir }}/guacenc:/certs/guacenc:ro
      - {{ arsenale_cert_dir }}/ssh-gateway:/certs/ssh-gateway:ro
    healthcheck:
      test: ["CMD-SHELL", "node -e \"const fs=require('fs');const http=require('http');const https=require('https');const useTls=Boolean(process.env.SERVER_TLS_CERT&&process.env.SERVER_TLS_KEY);const request=useTls?https:http;const options=useTls?{hostname:'localhost',port:3001,path:'/api/health',ca:fs.readFileSync('/certs/ca.pem')}:{hostname:'localhost',port:3001,path:'/api/health'};request.get(options,res=>{res.resume();process.exit(res.statusCode===200?0:1);}).on('error',()=>process.exit(1));\""]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s
    depends_on:
      postgres:
        condition: service_healthy
      guacd:
        condition: service_healthy
      gocache-cache:
        condition: service_healthy
      gocache-pubsub:
        condition: service_healthy
    restart: always
    networks:
      - net-db
      - net-guacd
      - net-guacenc
      - net-cache
      - net-edge
      - net-gateway

  # ---------------------------------------------------------------------------
  # Client — React SPA served by Nginx
  # ---------------------------------------------------------------------------
  client:
{% if _build | bool %}
    build:
      context: {{ _home }}{% if not (_is_dev | default(false) | bool) %}/arsenale{% endif %}

      dockerfile: client/Dockerfile
{% else %}
    image: {{ arsenale_registry }}/client:{{ arsenale_image_tag }}
{% endif %}
    container_name: arsenale-client
    read_only: true
    cpus: "{{ arsenale_resource_limits.client.cpus }}"
    mem_limit: "{{ arsenale_resource_limits.client.memory }}"
    pids_limit: {{ arsenale_resource_limits.client.pids }}
    tmpfs:
      - /tmp
      - /run
      - /var/cache/nginx
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    ports:
      - "{{ _client_bind_host }}:{{ arsenale_client_port }}:8080"
{% if not (_is_dev | default(false) | bool) %}
    volumes:
      - {{ arsenale_cert_dir }}/ca.pem:/certs/ca.pem:ro
{% endif %}
{% if _is_dev | default(false) | bool %}
    volumes:
      - {{ arsenale_cert_dir }}/client:/certs:ro
      - {{ _home }}/client/nginx.dev.conf:/etc/nginx/conf.d/default.conf:ro
    entrypoint: ["nginx", "-g", "daemon off;"]
{% endif %}
    healthcheck:
{% if _is_dev | default(false) | bool %}
      test: ["CMD-SHELL", "curl --silent --show-error --fail --cacert /certs/ca.pem https://localhost:8080/health >/dev/null || exit 1"]
{% else %}
      test: ["CMD-SHELL", "curl --silent --show-error --fail http://127.0.0.1:8080/health >/dev/null || exit 1"]
{% endif %}
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 5s
    depends_on:
      server:
        condition: service_healthy
    restart: always
    networks:
      - net-edge

  # ---------------------------------------------------------------------------
  # SSH Gateway — Managed SSH tunnel for TCP port forwarding
  # ---------------------------------------------------------------------------
  ssh-gateway:
{% if _build | bool %}
    build:
      context: {{ _home }}{% if not (_is_dev | default(false) | bool) %}/arsenale{% endif %}

      dockerfile: gateways/ssh-gateway/Dockerfile
{% else %}
    image: {{ arsenale_registry }}/ssh-gateway:{{ arsenale_image_tag }}
{% endif %}
    container_name: arsenale-ssh-gateway
    read_only: true
    cpus: "{{ arsenale_resource_limits.ssh_gateway.cpus }}"
    mem_limit: "{{ arsenale_resource_limits.ssh_gateway.memory }}"
    pids_limit: {{ arsenale_resource_limits.ssh_gateway.pids }}
    tmpfs:
      - /tmp
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    environment:
      SPIFFE_TRUST_DOMAIN: "{{ arsenale_spiffe_trust_domain | default('arsenale.local') }}"
      GATEWAY_API_TLS_CERT: /certs/server-cert.pem
      GATEWAY_API_TLS_KEY: /certs/server-key.pem
      GATEWAY_GRPC_TLS_CA: /certs/ca.pem
      GATEWAY_GRPC_CLIENT_CA: /certs/client-ca.pem
      GATEWAY_GRPC_TLS_CERT: /certs/server-cert.pem
      GATEWAY_GRPC_TLS_KEY: /certs/server-key.pem
      GATEWAY_GRPC_EXPECTED_SPIFFE_ID: "spiffe://{{ arsenale_spiffe_trust_domain | default('arsenale.local') }}/service/server"
{% if not (_is_dev | default(false) | bool) %}
    ports:
      - "{{ arsenale_ssh_port }}:2222"
{% endif %}
    volumes:
      - {{ _home }}/config/ssh-gateway/authorized_keys:/config/authorized_keys:ro
      - {{ arsenale_cert_dir }}/ssh-gateway:/certs:ro
    healthcheck:
      test: ["CMD-SHELL", "nc -z localhost 2222 || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 3
    restart: always
    networks:
      - net-gateway

{% if _is_dev | default(false) | bool %}

  # ---------------------------------------------------------------------------
  # Development tunnel gateways — end-to-end tunnel registration fixtures
  # ---------------------------------------------------------------------------
  dev-tunnel-ssh-gateway:
{% if _build | bool %}
    build:
      context: {{ _home }}
      dockerfile: gateways/ssh-gateway/Dockerfile
{% else %}
    image: {{ arsenale_registry }}/ssh-gateway:{{ arsenale_image_tag }}
{% endif %}
    container_name: arsenale-dev-tunnel-ssh-gateway
    read_only: true
    cpus: "{{ arsenale_resource_limits.ssh_gateway.cpus }}"
    mem_limit: "{{ arsenale_resource_limits.ssh_gateway.memory }}"
    pids_limit: {{ arsenale_resource_limits.ssh_gateway.pids }}
    tmpfs:
      - /tmp
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    environment:
      SPIFFE_TRUST_DOMAIN: "{{ arsenale_spiffe_trust_domain | default('arsenale.local') }}"
      TUNNEL_SERVER_URL: "wss://server:3011/api/tunnel/connect"
      TUNNEL_TOKEN: "${DEV_TUNNEL_MANAGED_SSH_TOKEN}"
      TUNNEL_GATEWAY_ID: "${DEV_TUNNEL_MANAGED_SSH_GATEWAY_ID}"
      TUNNEL_LOCAL_HOST: "127.0.0.1"
      TUNNEL_LOCAL_PORT: "2222"
      TUNNEL_CA_CERT_FILE: /tunnel-certs/ca.pem
      TUNNEL_CLIENT_CERT_FILE: /tunnel-certs/client-cert.pem
      TUNNEL_CLIENT_KEY_FILE: /tunnel-certs/client-key.pem
      GATEWAY_GRPC_TLS_CA: /certs/ca.pem
      GATEWAY_GRPC_CLIENT_CA: /certs/client-ca.pem
      GATEWAY_GRPC_TLS_CERT: /certs/server-cert.pem
      GATEWAY_GRPC_TLS_KEY: /certs/server-key.pem
      GATEWAY_GRPC_EXPECTED_SPIFFE_ID: "spiffe://{{ arsenale_spiffe_trust_domain | default('arsenale.local') }}/service/server"
    volumes:
      - {{ _home }}/config/ssh-gateway/authorized_keys:/config/authorized_keys:ro
      - {{ arsenale_cert_dir }}/ssh-gateway:/certs:ro
      - {{ arsenale_cert_dir }}/tunnel-managed-ssh:/tunnel-certs:ro
    depends_on:
      server:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "nc -z localhost 2222 || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 3
    restart: always
    networks:
      - net-gateway

  dev-tunnel-guacd:
{% if _build | bool %}
    build:
      context: {{ _home }}
      dockerfile: gateways/guacd/Dockerfile
{% else %}
    image: {{ arsenale_registry }}/guacd:{{ arsenale_image_tag }}
{% endif %}
    container_name: arsenale-dev-tunnel-guacd
    read_only: true
    cpus: "{{ arsenale_resource_limits.guacd.cpus }}"
    mem_limit: "{{ arsenale_resource_limits.guacd.memory }}"
    pids_limit: {{ arsenale_resource_limits.guacd.pids }}
    tmpfs:
      - /tmp
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    environment:
      TUNNEL_SERVER_URL: "wss://server:3011/api/tunnel/connect"
      TUNNEL_TOKEN: "${DEV_TUNNEL_GUACD_TOKEN}"
      TUNNEL_GATEWAY_ID: "${DEV_TUNNEL_GUACD_GATEWAY_ID}"
      TUNNEL_LOCAL_HOST: "127.0.0.1"
      TUNNEL_LOCAL_PORT: "4822"
      TUNNEL_CA_CERT_FILE: /tunnel-certs/ca.pem
      TUNNEL_CLIENT_CERT_FILE: /tunnel-certs/client-cert.pem
      TUNNEL_CLIENT_KEY_FILE: /tunnel-certs/client-key.pem
    volumes:
      - {{ arsenale_cert_dir }}/tunnel-guacd:/tunnel-certs:ro
    depends_on:
      server:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "node -e \"const net=require('net');const socket=net.connect({host:'127.0.0.1',port:4822});socket.on('connect',()=>{socket.end();process.exit(0);});socket.on('error',()=>process.exit(1));setTimeout(()=>process.exit(1),2000);\""]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 10s
    restart: always
    networks:
      - net-gateway

  dev-tunnel-db-proxy:
{% if _build | bool %}
    build:
      context: {{ _home }}
      dockerfile: gateways/db-proxy/Dockerfile
{% else %}
    image: {{ arsenale_registry }}/db-proxy:{{ arsenale_image_tag }}
{% endif %}
    container_name: arsenale-dev-tunnel-db-proxy
    read_only: true
    cpus: "{{ arsenale_resource_limits.db_proxy.cpus }}"
    mem_limit: "{{ arsenale_resource_limits.db_proxy.memory }}"
    pids_limit: {{ arsenale_resource_limits.db_proxy.pids }}
    tmpfs:
      - /tmp
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    environment:
      DB_LISTEN_PORT: "5432"
      TUNNEL_SERVER_URL: "wss://server:3011/api/tunnel/connect"
      TUNNEL_TOKEN: "${DEV_TUNNEL_DB_PROXY_TOKEN}"
      TUNNEL_GATEWAY_ID: "${DEV_TUNNEL_DB_PROXY_GATEWAY_ID}"
      TUNNEL_LOCAL_HOST: "127.0.0.1"
      TUNNEL_LOCAL_PORT: "5432"
      TUNNEL_CA_CERT_FILE: /tunnel-certs/ca.pem
      TUNNEL_CLIENT_CERT_FILE: /tunnel-certs/client-cert.pem
      TUNNEL_CLIENT_KEY_FILE: /tunnel-certs/client-key.pem
    volumes:
      - {{ arsenale_cert_dir }}/tunnel-db-proxy:/tunnel-certs:ro
    depends_on:
      server:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "node -e \"const net=require('net');const socket=net.connect({host:'127.0.0.1',port:5432});socket.on('connect',()=>{socket.end();process.exit(0);});socket.on('error',()=>process.exit(1));setTimeout(()=>process.exit(1),2000);\""]
      interval: 10s
      timeout: 5s
      retries: 3
    restart: always
    networks:
      - net-gateway

{% endif %}

