    environment:
      PORT: "8095"
      ARSENALE_VERSION: "{{ arsenale_image_tag }}"
    ports:
      - "127.0.0.1:18095:8095"
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://127.0.0.1:8095/healthz >/dev/null || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 5s
    restart: always
    networks:
      - net-edge

  terminal-target:
    build:
      context: {{ _home }}
      dockerfile: infrastructure/dev/terminal-target/Dockerfile
    container_name: arsenale-terminal-target
    read_only: true
    cpus: "{{ arsenale_resource_limits.go_service.cpus }}"
    mem_limit: "128m"
    pids_limit: {{ arsenale_resource_limits.go_service.pids }}
    tmpfs:
      - /tmp
      - /run
    healthcheck:
      test: ["CMD-SHELL", "nc -z 127.0.0.1 2224 || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 5s
    restart: always
    networks:
      net-edge: {}
      net-gateway:
        aliases:
          - terminal-target

{% endif %}

  # ---------------------------------------------------------------------------
  # Server — Express.js API + WebSocket backend
  # ---------------------------------------------------------------------------
  server:
{% if _build | bool %}
    build:
      context: {{ _home }}{% if not (_is_dev | default(false) | bool) %}/arsenale{% endif %}

      dockerfile: server/Dockerfile
{% else %}
    image: {{ arsenale_registry }}/server:{{ arsenale_image_tag }}
{% endif %}
{% if arsenale_server_replicas | default(1) | int <= 1 %}
    container_name: arsenale-server
{% endif %}
{% if arsenale_server_replicas | default(1) | int > 1 %}
    deploy:
      replicas: {{ arsenale_server_replicas }}
{% endif %}
    read_only: true
    cpus: "{{ arsenale_resource_limits.server.cpus }}"
    mem_limit: "{{ arsenale_resource_limits.server.memory }}"
    pids_limit: {{ arsenale_resource_limits.server.pids }}
    tmpfs:
      - /tmp
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    secrets:
      - jwt_secret
      - guacamole_secret
      - server_encryption_key
      - database_url
      - guacenc_auth_token
      - smtp_pass
      - sendgrid_api_key
      - ses_secret_access_key
      - resend_api_key
      - mailgun_api_key
      - twilio_auth_token
      - sns_secret_access_key
      - vonage_api_secret
      - google_client_secret
      - microsoft_client_secret
      - github_client_secret
      - oidc_client_secret
      - ldap_bind_password
      - ai_api_key
    environment:
      NODE_ENV: "{{ arsenale_node_env }}"
      HIBP_FAIL_OPEN: "true"
      SPIFFE_TRUST_DOMAIN: "{{ arsenale_spiffe_trust_domain | default('arsenale.local') }}"
      NODE_EXTRA_CA_CERTS: /certs/ca.pem
      CLI_ENABLED: "{{ 'true' if (_is_dev | default(false) | bool) else 'false' }}"
      DEV_TUNNEL_CERT_DIR: "{{ '/certs' if (_is_dev | default(false) | bool) else '' }}"
      DEV_BOOTSTRAP_ADMIN_EMAIL: "{{ arsenale_dev_bootstrap_admin_email }}"
      DEV_BOOTSTRAP_ADMIN_USERNAME: "{{ arsenale_dev_bootstrap_admin_username }}"
      DEV_BOOTSTRAP_ADMIN_PASSWORD: "{{ arsenale_dev_bootstrap_admin_password }}"
      DEV_BOOTSTRAP_TENANT_NAME: "{{ arsenale_dev_bootstrap_tenant_name }}"
      LOG_LEVEL: "{{ arsenale_log_level | default('info') }}"
      LOG_HTTP_REQUESTS: "{{ arsenale_log_http_requests | default('false') }}"
      LOG_GUACAMOLE: "{{ arsenale_log_guacamole | default('false') }}"
      PORT: "3001"
      GUACAMOLE_WS_PORT: "3002"
      DATABASE_URL: ""
      CLIENT_URL: "https://{{ arsenale_domain }}:{{ arsenale_client_port }}"
      TRUST_PROXY: "{{ arsenale_trust_proxy_effective | string | lower }}"
      RATE_LIMIT_WHITELIST_CIDRS: "127.0.0.1/32,::1/128"
      COOKIE_SECURE: "{{ _cookie_secure | string | lower }}"
      GUACD_HOST: guacd
      GUACD_PORT: "4822"
      GUACD_SSL: "true"
      GUACD_CA_CERT: /certs/ca.pem
      GUACENC_SERVICE_URL: "https://guacenc:3003"
      GUACENC_USE_TLS: "true"
      GUACENC_TLS_CA: /certs/guacenc/ca.pem
      REDIS_URL: "redis://redis:6379/0"
      SERVER_TLS_CERT: /certs/server/server-cert.pem
      SERVER_TLS_KEY: /certs/server/server-key.pem
      TUNNEL_SERVER_CERT: /certs/server/server-cert.pem
      TUNNEL_SERVER_KEY: /certs/server/server-key.pem
      TUNNEL_SERVER_CA: /certs/ca.pem
      TUNNEL_STRICT_MTLS: "{{ 'true' if (_is_dev | default(false) | bool) else 'false' }}"
      RECORDING_ENABLED: "{{ arsenale_recording_enabled | string | lower }}"
      RECORDING_PATH: /recordings
      ALLOW_LOCAL_NETWORK: "{{ arsenale_allow_local_network | string | lower }}"
      LATERAL_MOVEMENT_DETECTION_ENABLED: "false"
      SELF_SIGNUP_ENABLED: "{{ arsenale_self_signup_enabled | string | lower }}"
      EMAIL_PROVIDER: "{{ arsenale_email_provider }}"
      GATEWAY_GRPC_TLS_CA: /certs/ca.pem
      GATEWAY_GRPC_TLS_CERT: /certs/ssh-gateway/client-cert.pem
      GATEWAY_GRPC_TLS_KEY: /certs/ssh-gateway/client-key.pem
      GO_QUERY_RUNNER_ENABLED: "true"
      GO_CONTROL_PLANE_API_URL: "http://control-plane-api-go:8080"
      GO_QUERY_RUNNER_URL: "http://query-runner-go:8093"
      GO_TUNNEL_BROKER_ENABLED: "true"
      GO_TUNNEL_BROKER_URL: "http://tunnel-broker-go:8092"
      TUNNEL_SERVER_URL: "ws://tunnel-broker-go:8092/api/tunnel/connect"
      GO_DESKTOP_BROKER_ENABLED: "true"
      INTERNAL_SERVER_HOST: "server"
      TUNNEL_TCP_PROXY_BIND_HOST: "0.0.0.0"
    volumes:
      - arsenale_drive:/guacd-drive
      - arsenale_recordings:/recordings
      - {{ arsenale_cert_dir }}/ca.pem:/certs/ca.pem:ro
{% if _is_dev | default(false) | bool %}
      - {{ arsenale_cert_dir }}/ca-key.pem:/certs/ca-key.pem:ro
      - {{ arsenale_cert_dir }}/tunnel-managed-ssh:/certs/tunnel-managed-ssh:ro
      - {{ arsenale_cert_dir }}/tunnel-guacd:/certs/tunnel-guacd:ro
      - {{ arsenale_cert_dir }}/tunnel-db-proxy:/certs/tunnel-db-proxy:ro
{% endif %}
      - {{ arsenale_cert_dir }}/server:/certs/server:ro
      - {{ arsenale_cert_dir }}/guacenc:/certs/guacenc:ro
      - {{ arsenale_cert_dir }}/ssh-gateway:/certs/ssh-gateway:ro
    healthcheck:
      test: ["CMD-SHELL", "node -e \"const fs=require('fs');const http=require('http');const https=require('https');const useTls=Boolean(process.env.SERVER_TLS_CERT&&process.env.SERVER_TLS_KEY);const request=useTls?https:http;const options=useTls?{hostname:'localhost',port:3001,path:'/api/health',ca:fs.readFileSync('/certs/ca.pem')}:{hostname:'localhost',port:3001,path:'/api/health'};request.get(options,res=>{res.resume();process.exit(res.statusCode===200?0:1);}).on('error',()=>process.exit(1));\""]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
      guacd:
        condition: service_healthy
      desktop-broker-go:
        condition: service_healthy
      tunnel-broker-go:
        condition: service_healthy
    restart: always
    networks:
      - net-db
      - net-guacd
      - net-guacenc
      - net-cache
      - net-edge
      - net-gateway

  # ---------------------------------------------------------------------------
  # Client — React SPA served by Nginx
  # ---------------------------------------------------------------------------
  client:
{% if _build | bool %}
    build:
      context: {{ _home }}{% if not (_is_dev | default(false) | bool) %}/arsenale{% endif %}

      dockerfile: client/Dockerfile
{% else %}
    image: {{ arsenale_registry }}/client:{{ arsenale_image_tag }}
{% endif %}
    container_name: arsenale-client
    read_only: true
    cpus: "{{ arsenale_resource_limits.client.cpus }}"
    mem_limit: "{{ arsenale_resource_limits.client.memory }}"
    pids_limit: {{ arsenale_resource_limits.client.pids }}
    tmpfs:
      - /tmp
      - /run
      - /var/cache/nginx
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    ports:
      - "{{ _client_bind_host }}:{{ arsenale_client_port }}:8080"
{% if not (_is_dev | default(false) | bool) %}
    volumes:
      - {{ arsenale_cert_dir }}/ca.pem:/certs/ca.pem:ro
{% endif %}
{% if _is_dev | default(false) | bool %}
    volumes:
      - {{ arsenale_cert_dir }}/client:/certs:ro
      - {{ _home }}/client/nginx.dev.conf:/etc/nginx/templates/default.conf.template:ro
{% endif %}
    healthcheck:
{% if _is_dev | default(false) | bool %}
      test: ["CMD-SHELL", "curl --silent --show-error --fail --cacert /certs/ca.pem https://localhost:8080/health >/dev/null || exit 1"]
{% else %}
      test: ["CMD-SHELL", "curl --silent --show-error --fail http://127.0.0.1:8080/health >/dev/null || exit 1"]
{% endif %}
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 5s
    depends_on:
      control-plane-api-go:
        condition: service_healthy
      server:
        condition: service_healthy
      desktop-broker-go:
        condition: service_healthy
    restart: always
    networks:
      - net-edge

  # ---------------------------------------------------------------------------
  # SSH Gateway — Managed SSH tunnel for TCP port forwarding
  # ---------------------------------------------------------------------------
  ssh-gateway:
{% if _build | bool %}
    build:
      context: {{ _home }}{% if not (_is_dev | default(false) | bool) %}/arsenale{% endif %}

      dockerfile: gateways/ssh-gateway/Dockerfile
{% else %}
    image: {{ arsenale_registry }}/ssh-gateway:{{ arsenale_image_tag }}
{% endif %}
    container_name: arsenale-ssh-gateway
    read_only: true
    cpus: "{{ arsenale_resource_limits.ssh_gateway.cpus }}"
    mem_limit: "{{ arsenale_resource_limits.ssh_gateway.memory }}"
    pids_limit: {{ arsenale_resource_limits.ssh_gateway.pids }}
    tmpfs:
      - /tmp
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    environment:
      SPIFFE_TRUST_DOMAIN: "{{ arsenale_spiffe_trust_domain | default('arsenale.local') }}"
      GATEWAY_API_TLS_CERT: /certs/server-cert.pem
      GATEWAY_API_TLS_KEY: /certs/server-key.pem
      GATEWAY_GRPC_TLS_CA: /certs/ca.pem
      GATEWAY_GRPC_CLIENT_CA: /certs/client-ca.pem
      GATEWAY_GRPC_TLS_CERT: /certs/server-cert.pem
      GATEWAY_GRPC_TLS_KEY: /certs/server-key.pem
      GATEWAY_GRPC_EXPECTED_SPIFFE_ID: "spiffe://{{ arsenale_spiffe_trust_domain | default('arsenale.local') }}/service/server"
{% if not (_is_dev | default(false) | bool) %}
    ports:
      - "{{ arsenale_ssh_port }}:2222"
{% endif %}
    volumes:
      - {{ _home }}/config/ssh-gateway/authorized_keys:/config/authorized_keys:ro
      - {{ arsenale_cert_dir }}/ssh-gateway:/certs:ro
    healthcheck:
      test: ["CMD-SHELL", "nc -z localhost 2222 || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 3
    restart: always
    networks:
      - net-gateway

{% if _is_dev | default(false) | bool %}

  # ---------------------------------------------------------------------------
  # Development tunnel gateways — end-to-end tunnel registration fixtures
  # ---------------------------------------------------------------------------
  dev-tunnel-ssh-gateway:
{% if _build | bool %}
    build:
      context: {{ _home }}
      dockerfile: gateways/ssh-gateway/Dockerfile
{% else %}
    image: {{ arsenale_registry }}/ssh-gateway:{{ arsenale_image_tag }}
{% endif %}
    container_name: arsenale-dev-tunnel-ssh-gateway
    read_only: true
    cpus: "{{ arsenale_resource_limits.ssh_gateway.cpus }}"
    mem_limit: "{{ arsenale_resource_limits.ssh_gateway.memory }}"
    pids_limit: {{ arsenale_resource_limits.ssh_gateway.pids }}
    tmpfs:
      - /tmp
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    environment:
      SPIFFE_TRUST_DOMAIN: "{{ arsenale_spiffe_trust_domain | default('arsenale.local') }}"
      TUNNEL_SERVER_URL: "ws://tunnel-broker-go:8092/api/tunnel/connect"
      TUNNEL_TOKEN: "${DEV_TUNNEL_MANAGED_SSH_TOKEN}"
      TUNNEL_GATEWAY_ID: "${DEV_TUNNEL_MANAGED_SSH_GATEWAY_ID}"
      TUNNEL_LOCAL_HOST: "127.0.0.1"
      TUNNEL_LOCAL_PORT: "2222"
      TUNNEL_CA_CERT_FILE: /tunnel-certs/ca.pem
      TUNNEL_CLIENT_CERT_FILE: /tunnel-certs/client-cert.pem
      TUNNEL_CLIENT_KEY_FILE: /tunnel-certs/client-key.pem
      GATEWAY_GRPC_TLS_CA: /certs/ca.pem
      GATEWAY_GRPC_CLIENT_CA: /certs/client-ca.pem
      GATEWAY_GRPC_TLS_CERT: /certs/server-cert.pem
      GATEWAY_GRPC_TLS_KEY: /certs/server-key.pem
      GATEWAY_GRPC_EXPECTED_SPIFFE_ID: "spiffe://{{ arsenale_spiffe_trust_domain | default('arsenale.local') }}/service/server"
    volumes:
      - {{ _home }}/config/ssh-gateway/authorized_keys:/config/authorized_keys:ro
      - {{ arsenale_cert_dir }}/ssh-gateway:/certs:ro
      - {{ arsenale_cert_dir }}/tunnel-managed-ssh:/tunnel-certs:ro
    depends_on:
      tunnel-broker-go:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "nc -z localhost 2222 || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 3
    restart: always
    networks:
      - net-gateway

  dev-tunnel-guacd:
{% if _build | bool %}
    build:
      context: {{ _home }}
      dockerfile: gateways/guacd/Dockerfile
{% else %}
    image: {{ arsenale_registry }}/guacd:{{ arsenale_image_tag }}
{% endif %}
    container_name: arsenale-dev-tunnel-guacd
    read_only: true
    cpus: "{{ arsenale_resource_limits.guacd.cpus }}"
    mem_limit: "{{ arsenale_resource_limits.guacd.memory }}"
    pids_limit: {{ arsenale_resource_limits.guacd.pids }}
    tmpfs:
      - /tmp
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    environment:
      TUNNEL_SERVER_URL: "ws://tunnel-broker-go:8092/api/tunnel/connect"
      TUNNEL_TOKEN: "${DEV_TUNNEL_GUACD_TOKEN}"
      TUNNEL_GATEWAY_ID: "${DEV_TUNNEL_GUACD_GATEWAY_ID}"
      TUNNEL_LOCAL_HOST: "127.0.0.1"
      TUNNEL_LOCAL_PORT: "4822"
      TUNNEL_CA_CERT_FILE: /tunnel-certs/ca.pem
      TUNNEL_CLIENT_CERT_FILE: /tunnel-certs/client-cert.pem
      TUNNEL_CLIENT_KEY_FILE: /tunnel-certs/client-key.pem
    volumes:
      - {{ arsenale_cert_dir }}/tunnel-guacd:/tunnel-certs:ro
    depends_on:
      tunnel-broker-go:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "node -e \"const net=require('net');const socket=net.connect({host:'127.0.0.1',port:4822});socket.on('connect',()=>{socket.end();process.exit(0);});socket.on('error',()=>process.exit(1));setTimeout(()=>process.exit(1),2000);\""]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 10s
    restart: always
    networks:
      - net-gateway

  dev-tunnel-db-proxy:
{% if _build | bool %}
    build:
      context: {{ _home }}
      dockerfile: gateways/db-proxy/Dockerfile
{% else %}
    image: {{ arsenale_registry }}/db-proxy:{{ arsenale_image_tag }}
{% endif %}
    container_name: arsenale-dev-tunnel-db-proxy
    read_only: true
    cpus: "{{ arsenale_resource_limits.db_proxy.cpus }}"
    mem_limit: "{{ arsenale_resource_limits.db_proxy.memory }}"
    pids_limit: {{ arsenale_resource_limits.db_proxy.pids }}
    tmpfs:
      - /tmp
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    environment:
      DB_LISTEN_PORT: "5432"
      TUNNEL_SERVER_URL: "ws://tunnel-broker-go:8092/api/tunnel/connect"
      TUNNEL_TOKEN: "${DEV_TUNNEL_DB_PROXY_TOKEN}"
      TUNNEL_GATEWAY_ID: "${DEV_TUNNEL_DB_PROXY_GATEWAY_ID}"
      TUNNEL_LOCAL_HOST: "127.0.0.1"
      TUNNEL_LOCAL_PORT: "5432"
      TUNNEL_CA_CERT_FILE: /tunnel-certs/ca.pem
      TUNNEL_CLIENT_CERT_FILE: /tunnel-certs/client-cert.pem
      TUNNEL_CLIENT_KEY_FILE: /tunnel-certs/client-key.pem
    volumes:
      - {{ arsenale_cert_dir }}/tunnel-db-proxy:/tunnel-certs:ro
    depends_on:
      tunnel-broker-go:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "node -e \"const net=require('net');const socket=net.connect({host:'127.0.0.1',port:5432});socket.on('connect',()=>{socket.end();process.exit(0);});socket.on('error',()=>process.exit(1));setTimeout(()=>process.exit(1),2000);\""]
      interval: 10s
      timeout: 5s
      retries: 3
    restart: always
    networks:
      - net-gateway

{% endif %}

# =============================================================================
# Secrets — Podman external secrets (created by Ansible podman_secrets role)
# =============================================================================
secrets:
  jwt_secret:
    external: true
  guacamole_secret:
    external: true
  server_encryption_key:
    external: true
  database_url:
    external: true
  postgres_password:
    external: true
  guacenc_auth_token:
    external: true
  smtp_pass:
    external: true
  sendgrid_api_key:
    external: true
  ses_secret_access_key:
    external: true
  resend_api_key:
    external: true
  mailgun_api_key:
    external: true
  twilio_auth_token:
    external: true
  sns_secret_access_key:
    external: true
  vonage_api_secret:
    external: true
  google_client_secret:
    external: true
  microsoft_client_secret:
    external: true
  github_client_secret:
    external: true
  oidc_client_secret:
    external: true
  ldap_bind_password:
    external: true
  ai_api_key:
    external: true

# =============================================================================
# Volumes — Persistent data storage
# =============================================================================
volumes:
  pgdata:
  arsenale_drive:
  arsenale_recordings:

# =============================================================================
# Networks — Zero-trust segmented container networks
# =============================================================================
networks:
  net-db:
    name: arsenale-net-db
    internal: true
  net-guacd:
    name: arsenale-net-guacd
    internal: true
  net-guacenc:
    name: arsenale-net-guacenc
    internal: true
  net-cache:
    name: arsenale-net-cache
    internal: true
  net-edge:
    name: arsenale-net-edge
    internal: true
  net-gateway:
    name: arsenale-net-gateway
    internal: true
