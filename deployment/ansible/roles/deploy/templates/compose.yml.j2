# =============================================================================
# Arsenale — {{ arsenale_env | default('production') | capitalize }} Podman Compose (Ansible-managed)
# =============================================================================
# Generated by Ansible — do not edit manually.
# Environment: {{ arsenale_env | default('production') }}
# Secrets are managed via Podman secrets (mounted at /run/secrets/).
# =============================================================================

services:

  # ---------------------------------------------------------------------------
  # PostgreSQL — Primary database
  # ---------------------------------------------------------------------------
  postgres:
    image: postgres:16
    container_name: arsenale-postgres
    read_only: true
    tmpfs:
      - /tmp
      - /run/postgresql
    environment:
      POSTGRES_USER: "{{ arsenale_db_user }}"
      POSTGRES_DB: "{{ arsenale_db_name }}"
      POSTGRES_PASSWORD_FILE: /run/secrets/postgres_password
    secrets:
      - postgres_password
    volumes:
      - pgdata:/var/lib/postgresql/data
      - {{ arsenale_home }}{% if not (_is_dev | default(false) | bool) %}/arsenale{% endif %}/infrastructure/postgres/pg_hba.conf:/etc/postgresql/pg_hba.conf:ro
    command: ["postgres", "-c", "hba_file=/etc/postgresql/pg_hba.conf"]
    restart: always
    cap_drop:
      - ALL
    cap_add:
      - DAC_OVERRIDE
      - FOWNER
      - SETGID
      - SETUID
    security_opt:
      - no-new-privileges:true
{% if _is_dev | default(false) | bool %}
    ports:
      - "5432:5432"
{% endif %}
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ arsenale_db_user }} -d {{ arsenale_db_name }}"]
      interval: 5s
      timeout: 5s
      retries: 5
    networks:
      - net-db

  # ---------------------------------------------------------------------------
  # Apache Guacamole Daemon (guacd) — RDP/VNC protocol handler
  # ---------------------------------------------------------------------------
  guacd:
    image: {{ arsenale_guacd_image }}
    container_name: arsenale-guacd
    read_only: true
    tmpfs:
      - /tmp
    environment:
      GUACD_SSL: "true"
      GUACD_SSL_CERT: /certs/server-cert.pem
      GUACD_SSL_KEY: /certs/server-key.pem
    volumes:
      - arsenale_drive:/guacd-drive
      - arsenale_recordings:/recordings
      - {{ arsenale_cert_dir }}/guacd:/certs:ro
    restart: always
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    healthcheck:
      test: ["CMD-SHELL", "netstat -tln | grep -q ':4822 ' || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 10s
    networks:
      - net-guacd

  # ---------------------------------------------------------------------------
  # Guacenc — Session recording video converter
  # ---------------------------------------------------------------------------
  guacenc:
{% if arsenale_build_images | bool %}
    build:
      context: {{ arsenale_home }}{% if not (_is_dev | default(false) | bool) %}/arsenale{% endif %}/gateways/guacenc
      dockerfile: Dockerfile
{% else %}
    image: {{ arsenale_registry }}/guacenc:{{ arsenale_image_tag }}
{% endif %}
    container_name: arsenale-guacenc
    read_only: true
    tmpfs:
      - /tmp
    environment:
      GUACENC_AUTH_TOKEN_FILE: /run/secrets/guacenc_auth_token
      CACHE_SIDECAR_URL: "gocache:6380"
      CACHE_SIDECAR_TLS_CA: /certs/gocache/ca.pem
      CACHE_SIDECAR_TLS_CERT: /certs/gocache/client-cert.pem
      CACHE_SIDECAR_TLS_KEY: /certs/gocache/client-key.pem
    secrets:
      - guacenc_auth_token
    volumes:
      - arsenale_recordings:/recordings
      - {{ arsenale_cert_dir }}:/certs:ro
    depends_on:
      gocache:
        condition: service_healthy
    restart: always
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    healthcheck:
      test: ["CMD-SHELL", "python3 -c \"import urllib.request; urllib.request.urlopen('http://localhost:3003/health')\" || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 5s
    networks:
      - net-guacenc
      - net-cache

  # ---------------------------------------------------------------------------
  # GoCache — In-memory cache sidecar (gRPC)
  # ---------------------------------------------------------------------------
  gocache:
{% if arsenale_build_images | bool %}
    build:
      context: {{ arsenale_home }}{% if not (_is_dev | default(false) | bool) %}/arsenale{% endif %}/infrastructure/gocache
      dockerfile: Dockerfile
{% else %}
    image: {{ arsenale_registry }}/gocache:{{ arsenale_image_tag }}
{% endif %}
{% if arsenale_gocache_replicas | default(1) | int <= 1 %}
    container_name: arsenale-gocache
{% endif %}
{% if arsenale_gocache_replicas | default(1) | int > 1 %}
    deploy:
      replicas: {{ arsenale_gocache_replicas }}
{% endif %}
    read_only: true
    tmpfs:
      - /tmp
    environment:
      CACHE_LISTEN: "tcp://0.0.0.0:6380"
      CACHE_HEALTH_ADDR: "0.0.0.0:6381"
      CACHE_DISCOVERY: "{{ arsenale_gocache_peer_discovery }}"
{% if arsenale_gocache_peers %}
      CACHE_PEERS: "{{ arsenale_gocache_peers }}"
{% endif %}
      CACHE_TLS_CA: /certs/ca.pem
      CACHE_TLS_CERT: /certs/server-cert.pem
      CACHE_TLS_KEY: /certs/server-key.pem
    volumes:
      - gocache_data:/data
      - {{ arsenale_cert_dir }}/gocache:/certs:ro
{% if _is_dev | default(false) | bool %}
    ports:
      - "6380:6380"
      - "6381:6381"
{% endif %}
    restart: always
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://localhost:6381/health || exit 1"]
      interval: 10s
      timeout: 3s
      retries: 3
      start_period: 5s
    networks:
      - net-cache

  # ---------------------------------------------------------------------------
  # Server — Express.js API + WebSocket backend
  # ---------------------------------------------------------------------------
  server:
{% if arsenale_build_images | bool %}
    build:
      context: {{ arsenale_home }}{% if not (_is_dev | default(false) | bool) %}/arsenale{% endif %}

      dockerfile: server/Dockerfile
{% else %}
    image: {{ arsenale_registry }}/server:{{ arsenale_image_tag }}
{% endif %}
{% if arsenale_server_replicas | default(1) | int <= 1 %}
    container_name: arsenale-server
{% endif %}
{% if arsenale_server_replicas | default(1) | int > 1 %}
    deploy:
      replicas: {{ arsenale_server_replicas }}
{% endif %}
    read_only: true
    tmpfs:
      - /tmp
    cap_drop:
      - ALL
    cap_add:
      - NET_BIND_SERVICE
    security_opt:
      - no-new-privileges:true
    secrets:
      - jwt_secret
      - guacamole_secret
      - server_encryption_key
      - database_url
      - guacenc_auth_token
      - smtp_pass
      - sendgrid_api_key
      - ses_secret_access_key
      - resend_api_key
      - mailgun_api_key
      - twilio_auth_token
      - sns_secret_access_key
      - vonage_api_secret
      - google_client_secret
      - microsoft_client_secret
      - github_client_secret
      - oidc_client_secret
      - ldap_bind_password
      - ai_api_key
    environment:
      NODE_ENV: "{{ arsenale_node_env }}"
      LOG_LEVEL: "{{ arsenale_log_level | default('info') }}"
      LOG_HTTP_REQUESTS: "{{ arsenale_log_http_requests | default('false') }}"
      LOG_GUACAMOLE: "{{ arsenale_log_guacamole | default('false') }}"
      PORT: "3001"
      GUACAMOLE_WS_PORT: "3002"
      DATABASE_URL: ""
      CLIENT_URL: "https://{{ arsenale_domain }}:{{ arsenale_client_port }}"
      TRUST_PROXY: "{{ arsenale_trust_proxy }}"
      GUACD_HOST: guacd
      GUACD_PORT: "4822"
      GUACD_SSL: "true"
      GUACD_CA_CERT: /certs/ca.pem
      GUACENC_SERVICE_URL: "http://guacenc:3003"
      GUACENC_USE_TLS: "false"
      CACHE_SIDECAR_URL: "gocache:6380"
      CACHE_SIDECAR_ENABLED: "true"
      CACHE_SIDECAR_TLS_CA: /certs/gocache/ca.pem
      CACHE_SIDECAR_TLS_CERT: /certs/gocache/client-cert.pem
      CACHE_SIDECAR_TLS_KEY: /certs/gocache/client-key.pem
      SERVER_TLS_CERT: /certs/server/server-cert.pem
      SERVER_TLS_KEY: /certs/server/server-key.pem
      RECORDING_ENABLED: "{{ arsenale_recording_enabled }}"
      RECORDING_PATH: /recordings
      ALLOW_LOCAL_NETWORK: "{{ arsenale_allow_local_network }}"
      SELF_SIGNUP_ENABLED: "{{ arsenale_self_signup_enabled }}"
      EMAIL_PROVIDER: "{{ arsenale_email_provider }}"
      GATEWAY_GRPC_TLS_CA: /certs/ca.pem
      GATEWAY_GRPC_TLS_CERT: /certs/server/server-cert.pem
      GATEWAY_GRPC_TLS_KEY: /certs/server/server-key.pem
    volumes:
      - arsenale_drive:/guacd-drive
      - arsenale_recordings:/recordings
      - {{ arsenale_cert_dir }}:/certs:ro
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://localhost:3001/api/health || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s
    depends_on:
      postgres:
        condition: service_healthy
      guacd:
        condition: service_healthy
      gocache:
        condition: service_healthy
    restart: always
    networks:
      - net-db
      - net-guacd
      - net-guacenc
      - net-cache
      - net-gateway

  # ---------------------------------------------------------------------------
  # Client — React SPA served by Nginx
  # ---------------------------------------------------------------------------
  client:
{% if arsenale_build_images | bool %}
    build:
      context: {{ arsenale_home }}{% if not (_is_dev | default(false) | bool) %}/arsenale{% endif %}

      dockerfile: client/Dockerfile
{% else %}
    image: {{ arsenale_registry }}/client:{{ arsenale_image_tag }}
{% endif %}
    container_name: arsenale-client
    read_only: true
    tmpfs:
      - /tmp
      - /run
      - /var/cache/nginx
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    ports:
      - "{{ arsenale_client_port }}:8080"
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://localhost:8080/health || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 5s
    depends_on:
      server:
        condition: service_healthy
    restart: always
    networks:
      - net-gateway

  # ---------------------------------------------------------------------------
  # SSH Gateway — Managed SSH tunnel for TCP port forwarding
  # ---------------------------------------------------------------------------
  ssh-gateway:
{% if arsenale_build_images | bool %}
    build:
      context: {{ arsenale_home }}{% if not (_is_dev | default(false) | bool) %}/arsenale{% endif %}

      dockerfile: gateways/ssh-gateway/Dockerfile
{% else %}
    image: {{ arsenale_registry }}/ssh-gateway:{{ arsenale_image_tag }}
{% endif %}
    container_name: arsenale-ssh-gateway
    read_only: true
    tmpfs:
      - /tmp
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    environment:
      GATEWAY_API_TLS_CERT: /certs/server-cert.pem
      GATEWAY_API_TLS_KEY: /certs/server-key.pem
    ports:
      - "{{ arsenale_ssh_port }}:2222"
    volumes:
      - {{ arsenale_home }}{% if not (_is_dev | default(false) | bool) %}/{% endif %}config/ssh-gateway/authorized_keys:/config/authorized_keys:ro
      - {{ arsenale_cert_dir }}/ssh-gateway:/certs:ro
    healthcheck:
      test: ["CMD-SHELL", "nc -z localhost 2222 || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 3
    restart: always
    networks:
      - net-gateway

# =============================================================================
# Secrets — Podman external secrets (created by Ansible podman_secrets role)
# =============================================================================
secrets:
  jwt_secret:
    external: true
  guacamole_secret:
    external: true
  server_encryption_key:
    external: true
  database_url:
    external: true
  postgres_password:
    external: true
  guacenc_auth_token:
    external: true
  smtp_pass:
    external: true
  sendgrid_api_key:
    external: true
  ses_secret_access_key:
    external: true
  resend_api_key:
    external: true
  mailgun_api_key:
    external: true
  twilio_auth_token:
    external: true
  sns_secret_access_key:
    external: true
  vonage_api_secret:
    external: true
  google_client_secret:
    external: true
  microsoft_client_secret:
    external: true
  github_client_secret:
    external: true
  oidc_client_secret:
    external: true
  ldap_bind_password:
    external: true
  ai_api_key:
    external: true

# =============================================================================
# Volumes — Persistent data storage
# =============================================================================
volumes:
  gocache_data:
  pgdata:
  arsenale_drive:
  arsenale_recordings:

# =============================================================================
# Networks — Zero-trust segmented container networks
# =============================================================================
networks:
  net-db:
    name: arsenale-net-db
    internal: true
  net-guacd:
    name: arsenale-net-guacd
    internal: true
  net-guacenc:
    name: arsenale-net-guacenc
    internal: true
  net-cache:
    name: arsenale-net-cache
    internal: true
  net-gateway:
    name: arsenale-net-gateway
