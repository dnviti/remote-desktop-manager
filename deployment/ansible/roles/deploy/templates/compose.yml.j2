      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
      shared-files-s3:
        condition: service_started
    volumes:
      - arsenale_drive:/guacd-drive
      - arsenale_recordings:/recordings
      - /run/user/{{ arsenale_uid | default('1000') }}/podman/podman.sock:/run/podman/podman.sock
      - {{ arsenale_cert_dir }}/ca.pem:/certs/ca.pem:ro
      - {{ arsenale_cert_dir }}/guacd:/certs/guacd:ro
      - {{ arsenale_cert_dir }}/ssh-gateway:/certs/ssh-gateway:ro
{% if _is_dev | default(false) | bool %}
      - {{ arsenale_cert_dir }}/ca-key.pem:/certs/ca-key.pem:ro
{% endif %}
      - {{ arsenale_cert_dir }}/postgres:/certs/postgres:ro
      - {{ arsenale_cert_dir }}/guacenc:/certs/guacenc:ro
{% if _dev_tunnel_fixtures_enabled %}
      - {{ arsenale_cert_dir }}/tunnel-managed-ssh:/certs/tunnel-managed-ssh:ro
      - {{ arsenale_cert_dir }}/tunnel-guacd:/certs/tunnel-guacd:ro
      - {{ arsenale_cert_dir }}/tunnel-db-proxy:/certs/tunnel-db-proxy:ro
{% endif %}
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://127.0.0.1:8080/healthz >/dev/null || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 5s
    restart: always
    networks:
      - net-egress
      - net-edge
      - net-db
      - net-cache
      - net-guacd
      - net-gateway

  control-plane-controller:
{{ compose_service_source('control-plane-controller', 'backend/Dockerfile', build_args={'SERVICE': 'control-plane-controller'}) | indent(4, true) }}
