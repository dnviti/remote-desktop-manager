# =============================================================================
# Arsenale — {{ arsenale_env | default('production') | capitalize }} Podman Compose (Ansible-managed)
# =============================================================================
# Generated by Ansible — do not edit manually.
# Environment: {{ arsenale_env | default('production') }}
# Secrets are managed via Podman secrets (mounted at /run/secrets/).
# =============================================================================

services:

  # ---------------------------------------------------------------------------
  # PostgreSQL — Primary database
  # ---------------------------------------------------------------------------
  postgres:
    image: {{ arsenale_postgres_image }}
    container_name: arsenale-postgres
    user: "0:0"
    read_only: true
    cpus: "{{ arsenale_resource_limits.postgres.cpus }}"
    mem_limit: "{{ arsenale_resource_limits.postgres.memory }}"
    pids_limit: {{ arsenale_resource_limits.postgres.pids }}
    tmpfs:
      - /tmp
      - /var/lib/pgsql
      - /run/postgresql
    environment:
      POSTGRES_USER: "{{ arsenale_db_user }}"
      POSTGRES_DB: "{{ arsenale_db_name }}"
      POSTGRES_PASSWORD_FILE: /run/secrets/postgres_password
    secrets:
      - postgres_password
    volumes:
      - pgdata:{{ arsenale_postgres_data_dir | default('/var/lib/pgsql/data') }}
      - {{ _home }}{% if not (_is_dev | default(false) | bool) %}/arsenale{% endif %}/infrastructure/postgres/pg_hba.conf:/etc/postgresql/pg_hba.conf:ro
      - {{ arsenale_cert_dir }}/postgres:/certs:ro
      - {{ _home }}{% if not (_is_dev | default(false) | bool) %}/arsenale{% endif %}/infrastructure/postgres/entrypoint.sh:/usr/local/bin/arsenale-postgres-entrypoint.sh:ro
    entrypoint: ["/usr/local/bin/arsenale-postgres-entrypoint.sh"]
    restart: always
    cap_drop:
      - ALL
    cap_add:
      - CHOWN
      - DAC_OVERRIDE
      - FOWNER
      - SETGID
      - SETUID
    security_opt:
      - no-new-privileges:true
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ arsenale_db_user }} -d {{ arsenale_db_name }}"]
      interval: 5s
      timeout: 5s
      retries: 5
    networks:
      - net-db

  migrate:
    build:
      context: {{ (_home if (_is_dev | default(false) | bool) else (_home + '/arsenale')) }}
      dockerfile: backend/Dockerfile
      args:
        SERVICE: control-plane-api
    container_name: arsenale-migrate
    entrypoint: ["/usr/local/bin/migrate"]
    command: ["up"]
    read_only: true
    cpus: "0.25"
    mem_limit: "256m"
    pids_limit: 64
    tmpfs:
      - /tmp
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    secrets:
      - database_url
    environment:
      DATABASE_URL_FILE: /run/secrets/database_url
      DATABASE_SSL_ROOT_CERT: /certs/postgres/ca.pem
      ARSENALE_SKIP_MIGRATION_CHECK: "true"
    depends_on:
      postgres:
        condition: service_healthy
    volumes:
      - {{ arsenale_cert_dir }}/postgres:/certs/postgres:ro
    restart: "no"
    networks:
      - net-db

  # ---------------------------------------------------------------------------
  # Apache Guacamole Daemon (guacd) — RDP/VNC protocol handler
  # ---------------------------------------------------------------------------
  guacd:
{% if _build | bool %}
    build:
      context: {{ (_home if (_is_dev | default(false) | bool) else (_home + '/arsenale')) }}
      dockerfile: gateways/guacd/Dockerfile
{% else %}
    image: {{ arsenale_guacd_image }}
{% endif %}
    container_name: arsenale-guacd
    read_only: true
    cpus: "{{ arsenale_resource_limits.guacd.cpus }}"
    mem_limit: "{{ arsenale_resource_limits.guacd.memory }}"
    pids_limit: {{ arsenale_resource_limits.guacd.pids }}
    tmpfs:
      - /tmp
    environment:
      GUACD_SSL: "true"
      GUACD_SSL_CERT: /certs/server-cert.pem
      GUACD_SSL_KEY: /certs/server-key.pem
    volumes:
      - arsenale_drive:/guacd-drive
      - arsenale_recordings:/recordings
      - {{ arsenale_cert_dir }}/guacd:/certs:ro
    restart: always
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    healthcheck:
      test: ["CMD-SHELL", "netstat -tln | grep -q ':4822 ' || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 10s
    networks:
      - net-guacd

  # ---------------------------------------------------------------------------
  # Guacenc — Session recording video converter
  # ---------------------------------------------------------------------------
  guacenc:
{% if _build | bool %}
    build:
      context: {{ _home }}{% if not (_is_dev | default(false) | bool) %}/arsenale{% endif %}/gateways/guacenc
      dockerfile: Dockerfile
{% else %}
    image: {{ arsenale_registry }}/guacenc:{{ arsenale_image_tag }}
{% endif %}
    container_name: arsenale-guacenc
    read_only: true
    cpus: "{{ arsenale_resource_limits.guacenc.cpus }}"
    mem_limit: "{{ arsenale_resource_limits.guacenc.memory }}"
    pids_limit: {{ arsenale_resource_limits.guacenc.pids }}
    tmpfs:
      - /tmp
    environment:
      GUACENC_AUTH_TOKEN_FILE: /run/secrets/guacenc_auth_token
      REDIS_URL: "redis://redis:6379/0"
      GUACENC_TLS_CERT: /certs/guacenc/server-cert.pem
      GUACENC_TLS_KEY: /certs/guacenc/server-key.pem
    secrets:
      - guacenc_auth_token
    volumes:
      - arsenale_recordings:/recordings
      - {{ arsenale_cert_dir }}:/certs:ro
    restart: always
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    healthcheck:
      test: ["CMD-SHELL", "curl --silent --show-error --fail --insecure https://127.0.0.1:3003/health >/dev/null || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 5s
    networks:
      - net-guacenc
      - net-cache

  # ---------------------------------------------------------------------------
  # Redis — preferred distributed coordination backend
  # ---------------------------------------------------------------------------
  redis:
    image: quay.io/sclorg/redis-7-c9s
    container_name: arsenale-redis
    command:
      - run-redis
      - --appendonly
      - "yes"
    cpus: "0.5"
    mem_limit: "256m"
    pids_limit: 256
    tmpfs:
      - /tmp
    restart: always
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    volumes:
      - arsenale_redis:/var/lib/redis/data
    healthcheck:
      test: ["CMD-SHELL", "redis-cli -h 127.0.0.1 -p 6379 ping | grep -q PONG"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 5s
    networks:
      - net-cache

{% if not (_is_dev | default(false) | bool) %}
  # ---------------------------------------------------------------------------
  # Go backend foundation services required in production
  # ---------------------------------------------------------------------------
  control-plane-api:
    build:
      context: {{ _home }}/arsenale
      dockerfile: backend/Dockerfile
      args:
        SERVICE: control-plane-api
    container_name: arsenale-control-plane-api
    entrypoint:
      - /bin/sh
      - -lc
      - mkdir -p /guacd-drive /recordings && chmod 1777 /guacd-drive /recordings && exec /usr/local/bin/service
    user: "0:0"
    read_only: true
    cpus: "{{ arsenale_resource_limits.go_service.cpus }}"
    mem_limit: "{{ arsenale_resource_limits.go_service.memory }}"
    pids_limit: {{ arsenale_resource_limits.go_service.pids }}
    tmpfs:
      - /tmp
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    secrets:
      - database_url
      - guacamole_secret
      - guacenc_auth_token
      - jwt_secret
      - server_encryption_key
    environment:
      PORT: "8080"
      ARSENALE_VERSION: "{{ arsenale_image_tag }}"
      GO_QUERY_RUNNER_ENABLED: "true"
      HIBP_FAIL_OPEN: "true"
      DRIVE_BASE_PATH: "/guacd-drive"
      FILE_UPLOAD_MAX_SIZE: "10485760"
      USER_DRIVE_QUOTA: "104857600"
      DATABASE_URL_FILE: /run/secrets/database_url
      DATABASE_SSL_ROOT_CERT: /certs/postgres/ca.pem
      REDIS_URL: "redis://redis:6379/0"
      RECORDING_PATH: "/recordings"
      GUACAMOLE_SECRET_FILE: /run/secrets/guacamole_secret
      GUACENC_AUTH_TOKEN_FILE: /run/secrets/guacenc_auth_token
      GUACENC_SERVICE_URL: "https://guacenc:3003"
      GUACENC_USE_TLS: "true"
      GUACENC_TLS_CA: /certs/guacenc/ca.pem
      GUACENC_TIMEOUT_MS: "120000"
      GUACENC_RECORDING_PATH: "/recordings"
      ASCIICAST_CONVERTER_URL: "https://guacenc:3003"
      JWT_SECRET_FILE: /run/secrets/jwt_secret
      SERVER_ENCRYPTION_KEY_FILE: /run/secrets/server_encryption_key
    ports:
      - "{{ arsenale_service_bind_host | default('0.0.0.0') }}:18080:8080"
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
    volumes:
      - arsenale_drive:/guacd-drive
      - arsenale_recordings:/recordings
      - {{ arsenale_cert_dir }}/postgres:/certs/postgres:ro
      - {{ arsenale_cert_dir }}/guacenc:/certs/guacenc:ro
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://127.0.0.1:8080/healthz >/dev/null || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 5s
    restart: always
    networks:
      - net-egress
      - net-edge
      - net-db
      - net-cache
      - net-guacd
      - net-gateway

  tunnel-broker:
    build:
      context: {{ _home }}/arsenale/
      dockerfile: backend/Dockerfile
      args:
        SERVICE: tunnel-broker
    container_name: arsenale-tunnel-broker
    read_only: true
    cpus: "0.5"
    mem_limit: "256m"
    pids_limit: 128
    tmpfs:
      - /tmp
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    secrets:
      - database_url
      - server_encryption_key
    environment:
      PORT: "8092"
      ARSENALE_VERSION: "{{ arsenale_image_tag }}"
      DATABASE_URL_FILE: /run/secrets/database_url
      DATABASE_SSL_ROOT_CERT: /certs/postgres/ca.pem
      SERVER_ENCRYPTION_KEY_FILE: /run/secrets/server_encryption_key
      SPIFFE_TRUST_DOMAIN: "{{ arsenale_spiffe_trust_domain | default('arsenale.local') }}"
      TUNNEL_TCP_PROXY_BIND_HOST: "0.0.0.0"
      TUNNEL_TCP_PROXY_ADVERTISE_HOST: "tunnel-broker"
    ports:
      - "{{ arsenale_service_bind_host | default('0.0.0.0') }}:18092:8092"
    depends_on:
      postgres:
        condition: service_healthy
    volumes:
      - {{ arsenale_cert_dir }}/postgres:/certs/postgres:ro
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://127.0.0.1:8092/healthz >/dev/null || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 5s
    restart: always
    networks:
      - net-edge
      - net-db
      - net-gateway

  query-runner:
    build:
      context: {{ _home }}/arsenale
      dockerfile: backend/Dockerfile
      args:
        SERVICE: query-runner
    container_name: arsenale-query-runner
    read_only: true
    cpus: "{{ arsenale_resource_limits.go_service.cpus }}"
    mem_limit: "{{ arsenale_resource_limits.go_service.memory }}"
    pids_limit: {{ arsenale_resource_limits.go_service.pids }}
    tmpfs:
      - /tmp
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    secrets:
      - database_url
    environment:
      PORT: "8093"
      ARSENALE_VERSION: "{{ arsenale_image_tag }}"
      DATABASE_URL_FILE: /run/secrets/database_url
      DATABASE_SSL_ROOT_CERT: /certs/postgres/ca.pem
    ports:
      - "{{ arsenale_service_bind_host | default('0.0.0.0') }}:18093:8093"
    depends_on:
      postgres:
        condition: service_healthy
    volumes:
      - {{ arsenale_cert_dir }}/postgres:/certs/postgres:ro
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://127.0.0.1:8093/healthz >/dev/null || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 5s
    restart: always
    networks:
      - net-edge
      - net-db

  desktop-broker:
    build:
      context: {{ _home }}/arsenale
      dockerfile: backend/Dockerfile
      args:
        SERVICE: desktop-broker
    container_name: arsenale-desktop-broker
    read_only: true
    cpus: "{{ arsenale_resource_limits.go_service.cpus }}"
    mem_limit: "{{ arsenale_resource_limits.go_service.memory }}"
    pids_limit: {{ arsenale_resource_limits.go_service.pids }}
    tmpfs:
      - /tmp
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    secrets:
      - database_url
      - guacamole_secret
    environment:
      PORT: "8091"
      ARSENALE_VERSION: "{{ arsenale_image_tag }}"
      DATABASE_URL_FILE: /run/secrets/database_url
      DATABASE_SSL_ROOT_CERT: /certs/postgres/ca.pem
      GUACAMOLE_SECRET_FILE: /run/secrets/guacamole_secret
      GUACD_HOST: guacd
      GUACD_PORT: "4822"
      GUACD_SSL: "true"
      GUACD_CA_CERT: /certs/ca/ca.pem
    ports:
      - "{{ arsenale_service_bind_host | default('0.0.0.0') }}:18091:8091"
    depends_on:
      postgres:
        condition: service_healthy
      guacd:
        condition: service_healthy
    volumes:
      - arsenale_recordings:/recordings
      - {{ arsenale_cert_dir }}/postgres:/certs/postgres:ro
      - {{ arsenale_cert_dir }}:/certs/ca:ro
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://127.0.0.1:8091/healthz >/dev/null || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 5s
    restart: always
    networks:
      - net-edge
      - net-guacd
      - net-db
{% endif %}

{% if _is_dev | default(false) | bool %}
  # ---------------------------------------------------------------------------
  # Go backend foundation services — active public runtime
  # ---------------------------------------------------------------------------
  control-plane-api:
    build:
      context: {{ _home }}
      dockerfile: backend/Dockerfile
      args:
        SERVICE: control-plane-api
    container_name: arsenale-control-plane-api
    entrypoint:
      - /bin/sh
      - -lc
      - mkdir -p /guacd-drive /recordings && chmod 1777 /guacd-drive /recordings && exec /usr/local/bin/service
    user: "0:0"
    read_only: true
    cpus: "{{ arsenale_resource_limits.go_service.cpus }}"
    mem_limit: "{{ arsenale_resource_limits.go_service.memory }}"
    pids_limit: {{ arsenale_resource_limits.go_service.pids }}
    tmpfs:
      - /tmp
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    secrets:
      - database_url
      - guacamole_secret
      - guacenc_auth_token
      - jwt_secret
      - server_encryption_key
    environment:
      PORT: "8080"
      ARSENALE_VERSION: "{{ arsenale_image_tag }}"
      GO_QUERY_RUNNER_ENABLED: "true"
      HIBP_FAIL_OPEN: "true"
      CLIENT_URL: "{{ _public_url }}"
      WEBAUTHN_RP_ID: "{{ arsenale_domain }}"
      WEBAUTHN_RP_ORIGIN: "{{ _public_url }}"
