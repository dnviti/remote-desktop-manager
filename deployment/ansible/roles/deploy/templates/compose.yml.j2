  # ---------------------------------------------------------------------------
  # Client — React SPA served by Nginx
  # ---------------------------------------------------------------------------
  client:
{{ compose_service_source('client', 'client/Dockerfile') | indent(4, true) }}
    container_name: arsenale-client
    read_only: true
    cpus: "{{ arsenale_resource_limits.client.cpus }}"
    mem_limit: "{{ arsenale_resource_limits.client.memory }}"
    pids_limit: {{ arsenale_resource_limits.client.pids }}
    tmpfs:
      - /tmp
      - /run
      - /var/cache/nginx
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    ports:
      - "{{ _client_bind_host }}:{{ arsenale_client_port }}:8080"
    environment:
      API_UPSTREAM_HOST: "${API_UPSTREAM_HOST:-control-plane-api}"
      DESKTOP_UPSTREAM_HOST: "${DESKTOP_UPSTREAM_HOST:-desktop-broker}"
      MAP_ASSETS_UPSTREAM_HOST: "${MAP_ASSETS_UPSTREAM_HOST:-map-assets}"
      TERMINAL_UPSTREAM_HOST: "${TERMINAL_UPSTREAM_HOST:-terminal-broker}"
{% if _is_dev | default(false) | bool %}
    volumes:
      - {{ arsenale_cert_dir }}/client:/certs:ro
      - {{ _compose_repo_root }}/client/nginx.dev.conf:/etc/nginx/templates/default.conf.template:ro
{% endif %}
    healthcheck:
{% if _is_dev | default(false) | bool %}
      test: ["CMD-SHELL", "curl --silent --show-error --fail --insecure https://localhost:8080/health >/dev/null || exit 1"]
{% else %}
      test: ["CMD-SHELL", "curl --silent --show-error --fail http://127.0.0.1:8080/health >/dev/null || exit 1"]
{% endif %}
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 5s
    depends_on:
      control-plane-api:
        condition: service_healthy
      desktop-broker:
        condition: service_healthy
      map-assets:
        condition: service_healthy
      terminal-broker:
        condition: service_healthy
    restart: always
    networks:
      - net-edge

  # ---------------------------------------------------------------------------
  # SSH Gateway — Managed SSH tunnel for TCP port forwarding
  # ---------------------------------------------------------------------------
  ssh-gateway:
{{ compose_service_source('ssh-gateway', 'gateways/ssh-gateway/Dockerfile') | indent(4, true) }}
    container_name: arsenale-ssh-gateway
    read_only: true
    cpus: "{{ arsenale_resource_limits.ssh_gateway.cpus }}"
    mem_limit: "{{ arsenale_resource_limits.ssh_gateway.memory }}"
    pids_limit: {{ arsenale_resource_limits.ssh_gateway.pids }}
    tmpfs:
      - /tmp
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    environment:
      SPIFFE_TRUST_DOMAIN: "{{ arsenale_spiffe_trust_domain | default('arsenale.local') }}"
      GATEWAY_API_TLS_CERT: /certs/server-cert.pem
      GATEWAY_API_TLS_KEY: /certs/server-key.pem
      GATEWAY_GRPC_TLS_CA: /certs/ca.pem
      GATEWAY_GRPC_CLIENT_CA: /certs/client-ca.pem
      GATEWAY_GRPC_TLS_CERT: /certs/server-cert.pem
      GATEWAY_GRPC_TLS_KEY: /certs/server-key.pem
      GATEWAY_GRPC_EXPECTED_SPIFFE_ID: "spiffe://{{ arsenale_spiffe_trust_domain | default('arsenale.local') }}/service/control-plane-api"
{% if not (_is_dev | default(false) | bool) %}
    ports:
      - "{{ arsenale_ssh_port }}:2222"
{% endif %}
    volumes:
      - {{ _home }}/config/ssh-gateway/authorized_keys:/config/authorized_keys:ro
      - {{ arsenale_cert_dir }}/ssh-gateway:/certs:ro
    healthcheck:
      test: ["CMD-SHELL", "nc -z localhost 2222 || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 3
    restart: always
    networks:
      - net-egress
      - net-gateway

