# Arsenale firewall rules — generated by Ansible
# Restricts external access to web ({{ arsenale_client_port }}) and SSH ({{ arsenale_ssh_port }}) only

table inet arsenale {
  chain input {
    type filter hook input priority 0; policy drop;

    # Allow established connections
    ct state established,related accept
    ct state invalid drop

    # Allow loopback
    iif lo accept

    # Allow host SSH (port 22)
    tcp dport 22 accept

    # Allow Arsenale web UI
{% for source in arsenale_allowed_web_sources %}
    ip saddr {{ source }} tcp dport {{ arsenale_client_port }} accept
{% endfor %}

    # Allow Arsenale SSH gateway
{% for source in arsenale_allowed_ssh_sources %}
    ip saddr {{ source }} tcp dport {{ arsenale_ssh_port }} accept
{% endfor %}

    # Allow ICMP ping
    ip protocol icmp accept
    ip6 nexthdr icmpv6 accept

    # Log and drop everything else
    log prefix "arsenale-drop: " drop
  }

  chain forward {
    type filter hook forward priority 0; policy drop;

    # Allow established container traffic
    ct state established,related accept

    # Allow container egress for DNS only (port 53)
    tcp dport 53 accept
    udp dport 53 accept

    # Allow container egress for HTTPS (package updates, HIBP API, OAuth)
    tcp dport 443 accept

    # Allow container egress for SMTP
    tcp dport { 25, 465, 587 } accept

    # Drop all other forwarded traffic
    drop
  }

  chain output {
    type filter hook output priority 0; policy accept;
  }
}
