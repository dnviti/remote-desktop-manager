{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "namespace": {
      "type": "string",
      "minLength": 1
    },
    "ingress": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "host": {
          "type": "string"
        },
        "className": {
          "type": "string"
        },
        "tlsEnabled": {
          "type": "boolean"
        }
      }
    },
    "kubernetes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "replicas": {
          "type": "integer",
          "minimum": 1
        },
        "autoscaling": {
          "type": "object",
          "additionalProperties": true
        },
        "storageClass": {
          "type": "string"
        },
        "imagePullSecrets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "nodeSelector": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "tolerations": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "resources": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "rendered": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "resources": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        },
        "manifests": {
          "type": "string"
        }
      }
    }
  }
}
